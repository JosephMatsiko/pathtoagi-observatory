---
import Base from '../../layouts/Base.astro';
import { DISPATCHES, DISPATCH_KIND_LABEL } from '../../data/dispatches';

const dispatches = [...DISPATCHES].sort((a, b) => b.no - a.no);
---

<Base
  title="The Observatory Press — pathtoAGI"
  description="The record's publishing arm. Dispatches, data releases, and notices — every claim traceable to the record, corrections in the revision log, no embargoes, machine-readable everything."
>
  <section class="max-w-3xl">
    <p class="eyebrow">The Observatory Press</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">Dispatches from the record</h1>
    <p class="lede mt-6">
      A dispatch is not journalism about the record; it <em>is</em> the record,
      rendered for readers. The editorial charter is four lines: every claim
      traces to a record entry. Corrections happen in the
      <a href="/log/" class="link-accent">revision log</a>, never by silent
      edit. Obligations, never claims. No embargoes, no access, no exclusives —
      everything ships to everyone at once.
    </p>
    <p class="mono mt-4 text-xs" style="color: var(--color-faint);">
      Syndication: <a href="/press/feed.xml" class="hover:underline" style="color: var(--color-accent);">RSS</a>
      · machine-readable record: <a href="/record.json" class="hover:underline" style="color: var(--color-accent);">record.json</a>
      · provenance: <a href="/reproduce/" class="hover:underline" style="color: var(--color-accent);">reproduce every claim</a>
    </p>
  </section>

  <ul class="mt-12 space-y-6">
    {
      dispatches.map((d) => (
        <li class="surface p-7">
          <div class="flex flex-wrap items-center gap-3">
            <span class="mono text-xs" style="color: var(--color-accent);">
              No. {String(d.no).padStart(3, '0')}
            </span>
            <span class="mono text-xs" style="color: var(--color-faint);">
              {d.date}
            </span>
            <span
              class="mono rounded px-1.5 py-0.5 text-[0.62rem] uppercase tracking-wider"
              style="background: var(--color-surface-2); color: var(--color-accent);"
            >
              {DISPATCH_KIND_LABEL[d.kind]}
            </span>
          </div>
          <h2 class="serif mt-3 text-2xl" style="color: var(--color-ink);">
            <a href={`/press/${d.slug}/`} class="hover:underline">
              {d.title}
            </a>
          </h2>
          <p class="mt-2 max-w-2xl text-sm" style="color: var(--color-muted);">
            {d.standfirst}
          </p>
          <p class="mt-4">
            <a
              href={`/press/${d.slug}/`}
              class="mono text-xs hover:underline"
              style="color: var(--color-accent);"
            >
              Read the dispatch →
            </a>
          </p>
        </li>
      ))
    }
  </ul>

  <p class="mt-10 max-w-2xl text-sm" style="color: var(--color-muted);">
    The Press publishes what the record earns: dispatches when the record's
    meaning moves, data releases when its datasets change shape, notices when
    its methods do. An annual printed edition for research libraries is a
    standing ambition of the charter — planned, not yet begun.
  </p>
</Base>
