---
import Base from '../../layouts/Base.astro';
import { RUN_BUNDLES } from '../../data/run-bundles';
import { REVISIONS } from '../../data/revisions';
import { DISPATCHES } from '../../data/dispatches';

const latestBundle = RUN_BUNDLES[0];
const latestRevision = REVISIONS[0];
const latestDispatch = [...DISPATCHES].sort((a, b) => b.no - a.no)[0];
const latestDispatchPath = latestDispatch ? `/press/${latestDispatch.slug}/` : '/press/';
const nextActions = latestBundle?.pending?.length
  ? latestBundle.pending
  : ['human baseline', 'independent scorer', 'external reproduction', 'challenge window'];
const lanes = [
  ['Codex', 'builds deterministic surfaces, gates, deployment paths, and reproduction tools'],
  ['Claude', 'continues adjudication, record ceremony, operator continuity, and correction culture'],
  ['GPT-family', 'serves adversarial synthesis, rubric pressure, and Omnibus expansion discipline'],
];
---

<Base
  title="Builder Handoff - pathtoAGI"
  description="Re-entry note for Codex, Claude, GPT-family reviewers, and future builders: current lineage, scope boundary, active object, and next required action."
>
  <section class="max-w-3xl">
    <p class="eyebrow">Builder handoff · June 30-July 3 lineage</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">Resume from the record, not memory</h1>
    <p class="lede mt-6">
      Returning builders should not merge this Observatory with older PathToAGI
      material by feel. The current root of truth is this repo, the public
      deployment, the Omnibus adoption, and the revision record from the June 30
      rebuild forward.
    </p>
  </section>

  <section class="mt-10 grid gap-4 lg:grid-cols-3">
    {lanes.map(([name, role]) => (
      <div class="surface p-5">
        <p class="eyebrow">{name}</p>
        <p class="mt-3 text-sm" style="color: var(--color-muted);">{role}</p>
      </div>
    ))}
  </section>

  <section class="mt-14 ops-frame p-6">
    <p class="eyebrow">Current front of the record</p>
    <h2 class="serif mt-2 text-2xl" style="color: var(--color-ink);">{latestBundle?.title}</h2>
    <p class="mt-2 text-sm" style="color: var(--color-muted);">{latestBundle?.summary}</p>
    <div class="mt-5 grid gap-3 sm:grid-cols-3">
      <a href="/runs/" class="surface-quiet block p-4 no-underline">
        <p class="eyebrow">Run bundle</p>
        <p class="mono mt-2 text-xs" style="color: var(--color-accent);">{latestBundle?.id}</p>
      </a>
      <a href={latestDispatchPath} class="surface-quiet block p-4 no-underline">
        <p class="eyebrow">Latest dispatch</p>
        <p class="mono mt-2 text-xs" style="color: var(--color-accent);">No. {latestDispatch?.no}</p>
      </a>
      <a href="https://github.com/JosephMatsiko/pathtoagi-observatory/blob/main/docs/CLAUDE_REENTRY_2026_07_02.md" class="surface-quiet block p-4 no-underline">
        <p class="eyebrow">Boundary note</p>
        <p class="mono mt-2 text-xs" style="color: var(--color-accent);">Claude re-entry</p>
      </a>
    </div>
  </section>

  <section class="mt-14 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
    <div>
      <h2 class="serif text-2xl">Next honest work</h2>
      <p class="mt-2 text-sm" style="color: var(--color-muted);">
        Do not resume from a remembered plan. Resume from the current bundle’s
        pending list, then let the revision log say what changed.
      </p>
      <ol class="mt-5 space-y-2">
        {nextActions.map((action, index) => (
          <li class="flex gap-3 text-sm" style="color: var(--color-ink-dim);">
            <span class="mono text-xs" style="color: var(--color-accent);">{String(index + 1).padStart(2, '0')}</span>
            <span>{action}</span>
          </li>
        ))}
      </ol>
    </div>
    <div class="surface p-5">
      <p class="eyebrow">Latest record movement</p>
      <p class="serif mt-2 text-lg" style="color: var(--color-ink);">{latestRevision?.title}</p>
      <p class="mt-2 text-sm" style="color: var(--color-muted);">{latestRevision?.detail}</p>
    </div>
  </section>
</Base>
