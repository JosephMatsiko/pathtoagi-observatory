---
import Base from '../../layouts/Base.astro';
import { CYCLES } from '../../data/cycles';

const cycles = [...CYCLES].sort((a, b) => b.shippedAt.localeCompare(a.shippedAt));
const fileLabel: Record<string, string> = {
  'proposal.md': 'Scout proposal',
  'verdict.md': 'Adversary verdict',
  'calibration.md': 'Calibrator grading',
  'trace.json': 'Cycle trace',
};
---

<Base
  title="Published cycles — pathtoAGI"
  description="Every shipped maintenance cycle's working artifacts, verbatim: the Scout's proposal, the Adversary's verdict, the Calibrator's grading, the trace. Any change to the record can be traced from raw claim to adversarial review to ship."
>
  <section class="max-w-3xl">
    <p class="eyebrow">Provenance · the mesh, in public</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">Published cycles</h1>
    <p class="lede mt-6">
      The record is maintained by an adversarial mesh of three model families.
      When a cycle ships a change, its working artifacts are published here
      verbatim — the proposal, the independent adversary's verdict, the
      calibration grading, the trace — so any claim on the record can be traced
      from raw draft to adversarial review to ship. Disagreement is part of the
      record, not something edited out of it.
    </p>
  </section>

  <!-- The mesh, breathing: five coinhering lanes; the loop closes -->
  <figure class="mt-10" aria-label="The five-lane mesh: Scout feeds Adversary feeds Calibrator and Steward; Recursion closes the loop back to Scout.">
    <svg viewBox="0 0 640 150" class="mesh-svg" role="img">
      <defs>
        <marker id="mesh-arrow" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="6" markerHeight="6" orient="auto">
          <path d="M0,0 L8,4 L0,8 z" fill="var(--color-line)"></path>
        </marker>
      </defs>
      {[
        { x: 60, label: 'Scout', glyph: '◇', c: 'hsl(184 84% 54%)' },
        { x: 190, label: 'Adversary', glyph: '◆', c: 'hsl(8 84% 64%)' },
        { x: 320, label: 'Calibrator', glyph: '◈', c: 'hsl(270 60% 72%)' },
        { x: 450, label: 'Steward', glyph: '◉', c: 'hsl(152 58% 52%)' },
        { x: 580, label: 'Recursion', glyph: '⟳', c: 'hsl(34 96% 60%)' },
      ].map((n, i, all) => (
        <>
          {i < all.length - 1 && (
            <line class="mesh-flow" x1={n.x + 18} y1="60" x2={all[i + 1].x - 18} y2="60" stroke="var(--color-line)" stroke-width="1.2" marker-end="url(#mesh-arrow)" style={`animation-delay: ${i * 0.5}s;`}></line>
          )}
          <circle cx={n.x} cy="60" r="16" fill="var(--color-surface)" stroke={n.c} stroke-width="1.4"></circle>
          <text x={n.x} y="65" text-anchor="middle" font-size="13" fill={n.c}>{n.glyph}</text>
          <text x={n.x} y="98" text-anchor="middle" class="mesh-label" fill="var(--color-muted)">{n.label}</text>
        </>
      ))}
      <path class="mesh-flow mesh-close" d="M 580 78 Q 320 150 60 78" fill="none" stroke="hsl(34 96% 60%)" stroke-opacity="0.7" stroke-width="1.2" marker-end="url(#mesh-arrow)"></path>
      <text x="320" y="136" text-anchor="middle" class="mesh-label" fill="var(--color-faint)">the loop closes — recursion feeds scout</text>
    </svg>
  </figure>

  <ul class="mt-10 space-y-4">
    {
      cycles.map((c) => (
        <li class="surface p-6">
          <div class="flex flex-wrap items-center gap-3">
            <span class="mono text-xs" style="color: var(--color-accent);">
              {c.id}
            </span>
            <span class="mono text-xs" style="color: var(--color-faint);">
              shipped {c.shippedAt}
            </span>
            <span
              class="mono rounded px-1.5 py-0.5 text-[0.62rem] uppercase tracking-wider"
              style="background: var(--color-surface-2); color: hsl(8 84% 64%);"
            >
              adversary: {c.adversary}
            </span>
            {!c.files.includes('calibration.md') && (
              <span
                class="mono rounded px-1.5 py-0.5 text-[0.62rem] uppercase tracking-wider"
                style="background: var(--color-surface-2); color: hsl(34 96% 60%);"
              >
                calibration lane absent
              </span>
            )}
          </div>
          <p class="mt-2 text-sm" style="color: var(--color-muted);">
            {c.summary}
          </p>
          <p class="mt-3 flex flex-wrap gap-3">
            {c.files.map((f) => (
              <a
                href={`/cycles/${c.id}/${f}`}
                class="mono text-xs hover:underline"
                style="color: var(--color-accent);"
              >
                {fileLabel[f] ?? f} →
              </a>
            ))}
          </p>
        </li>
      ))
    }
  </ul>

  <p class="mt-8 max-w-2xl text-sm" style="color: var(--color-muted);">
    Artifacts are frozen at ship time and published from the shipping cycle
    forward ({cycles.length} so far). Lanes write for the record: no secrets, no
    private material — the gate and the mesh's mandates both bind them to that.
  </p>
</Base>

<style>
  .mesh-svg { width: 100%; max-width: 42rem; height: auto; display: block; }
  .mesh-label { font-family: var(--font-mono, monospace); font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; }
  .mesh-flow { stroke-dasharray: 5 6; animation: mesh-run 1.6s linear infinite; }
  .mesh-close { animation-duration: 2.6s; }
  @keyframes mesh-run { to { stroke-dashoffset: -22; } }
</style>
