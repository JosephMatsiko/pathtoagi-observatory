---
import Base from '../../layouts/Base.astro';
import ChallengeCourt from '../../components/ChallengeCourt.astro';
import { CHALLENGES } from '../../data/challenges';
---

<Base
  title="Refutation Register - pathtoAGI"
  description="The mechanical refutation register: re-derive any grading from the sealed artifacts, demonstrate a divergence, and force a public correction — adjudicated mechanically, open to any party, human or machine."
>
  <section class="max-w-3xl">
    <p class="eyebrow">Refutation register · correction trail</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">A place for contradiction</h1>
    <p class="lede mt-6">
      A record that cannot be contradicted is only decorated certainty. Since
      constitution v3 the path is mechanical and open to any party, human or
      machine: re-derive a grading from the sealed artifacts and show a
      divergence, show a seal that fails to verify, or demonstrate a grader is
      non-deterministic. A valid refutation forces a public correction — no
      panel, no discretion, no human able to veto it.
    </p>
  </section>

  <section class="mt-10">
    <ChallengeCourt />
  </section>

  <section class="mt-14">
    <div class="flex items-baseline justify-between gap-4">
      <h2 class="serif text-2xl">Refutation objects</h2>
      <a href="https://github.com/JosephMatsiko/pathtoagi-observatory/issues/new?title=refutation%3A+%3Crun-id%3E" class="link-accent text-sm">file on GitHub</a>
    </div>
    {CHALLENGES.length === 0 ? (
      <div class="surface mt-5 p-6">
        <p class="serif text-xl" style="color: var(--color-ink);">No refutation has been filed.</p>
        <p class="mt-2 text-sm" style="color: var(--color-muted);">
          This is not a badge of correctness. Every grading on this record can
          be re-derived from the public artifacts in minutes — the docket being
          empty means nobody has tried, and the record treats that as an
          invitation, not a victory.
        </p>
      </div>
    ) : (
      <ul class="mt-5 space-y-3">
        {CHALLENGES.map((challenge) => (
          <li class="surface p-5">
            <p class="mono text-xs" style="color: var(--color-faint);">{challenge.filedAt} · {challenge.status}</p>
            <p class="serif mt-2 text-lg" style="color: var(--color-ink);">{challenge.claim}</p>
            <p class="mt-1 text-sm" style="color: var(--color-muted);">{challenge.targets}</p>
          </li>
        ))}
      </ul>
    )}
  </section>
</Base>
