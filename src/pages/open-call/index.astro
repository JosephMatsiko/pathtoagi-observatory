---
import Base from '../../layouts/Base.astro';
import { OUTREACH } from '../../data/outreach';

const roleColor: Record<string, string> = {
  'adversarial challenger': 'var(--color-verdict)',
  'independent scorer': 'hsl(270 60% 72%)',
  'human baseline contributor': 'var(--color-affirm)',
  'rival instrument operator': 'var(--color-accent)',
};
---

<Base
  title="Open Call — pathtoAGI"
  description="The instrument's standing invitations to the people and systems it cannot manufacture: adversarial challengers, independent scorers, human-baseline players, and rival forkers."
>
  <section class="max-w-3xl">
    <p class="eyebrow">Open call · the record's bottleneck is people</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">Come break this, or help it earn its verdict</h1>
    <p class="lede mt-6">
      The machinery is built. What it cannot build is the one thing that makes
      a record trustworthy: other people, testing it, disagreeing with it,
      grading it, and racing it. Every role below is a genuine bottleneck the
      verdict protocol names — and each is a standing, public invitation, not a
      one-time ask.
    </p>
  </section>

  <section class="mt-12 grid gap-4 sm:grid-cols-2">
    {
      OUTREACH.map((c) => (
        <article class="surface p-6" style={`border-color: color-mix(in oklab, ${roleColor[c.role] ?? 'var(--color-line)'} 35%, var(--color-line));`}>
          <div class="flex items-center gap-3">
            <span class="mono text-[0.62rem] uppercase tracking-wider" style={`color: ${roleColor[c.role] ?? 'var(--color-accent)'};`}>
              {c.role}
            </span>
            <span class="mono ml-auto text-[0.62rem] uppercase tracking-wider" style="color: var(--color-affirm);">
              {c.status}
            </span>
          </div>
          <p class="mt-3 text-sm" style="color: var(--color-ink-dim);">{c.what}</p>
          <p class="mono mt-4 text-xs" style="color: var(--color-faint);">
            for: {c.who}
          </p>
          <p class="mono mt-1 text-xs" style="color: var(--color-faint);">
            channel: {c.channel}
          </p>
        </article>
      ))
    }
  </section>

  <section class="mt-12 max-w-3xl">
    <div class="surface-quiet p-6">
      <p class="eyebrow">Start here</p>
      <ul class="mt-3 space-y-2 text-sm" style="color: var(--color-ink-dim);">
        <li>· <strong>Play a sealed world</strong> right now — <a href="/play/" class="link-accent">/play/</a></li>
        <li>· <strong>Challenge any entry</strong> — <a href="https://github.com/JosephMatsiko/pathtoagi-observatory/issues/new?template=challenge.md" class="link-accent">GitHub challenge template</a></li>
        <li>· <strong>Fork the instrument</strong> — <a href="https://github.com/JosephMatsiko/pathtoagi-observatory/blob/main/RECORD_PROTOCOL.md" class="link-accent">RECORD_PROTOCOL.md</a></li>
        <li>· <strong>Score a probe independently</strong> — see <a href="https://github.com/JosephMatsiko/pathtoagi-observatory/blob/main/docs/INDEPENDENT_SCORING_INVITATION.md" class="link-accent">the invitation</a></li>
        <li>· <strong>Query the record as an agent</strong> — <a href="/to-the-systems-reading-this/" class="link-accent">the MCP / A2A channels</a></li>
      </ul>
    </div>
    <p class="prose mt-6">
      This page is honest about its own state: the outreach ledger is a governed
      record object, so when a challenge lands, a scorer signs on, or a fork
      registers, it is logged here and in the
      <a href="/log/" class="link-accent">revision log</a> — not lost in a
      founder's inbox. Relationships that outlive any one session are the point.
    </p>
  </section>
</Base>
