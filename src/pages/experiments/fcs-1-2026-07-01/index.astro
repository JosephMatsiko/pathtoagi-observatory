---
import Base from '../../../layouts/Base.astro';

// The artifacts are imported verbatim from the experiment directory at build
// time — the page cannot drift from the files it publishes.
import grading from '../../../../experiments/fcs-1-2026-07-01/GRADING.md?raw';
import prompt from '../../../../experiments/fcs-1-2026-07-01/prompt.txt?raw';
import transcriptGpt from '../../../../experiments/fcs-1-2026-07-01/transcript-gpt-5.5.txt?raw';
import transcriptClaude from '../../../../experiments/fcs-1-2026-07-01/transcript-claude.txt?raw';

const artifacts = [
  { id: 'grading', label: 'Grading (GRADING.md)', body: grading },
  { id: 'prompt', label: 'The prompt (prompt.txt)', body: prompt },
  { id: 'transcript-gpt-5-5', label: 'Transcript — GPT-5.5', body: transcriptGpt },
  { id: 'transcript-claude', label: 'Transcript — Claude', body: transcriptClaude },
];
---

<Base
  title="FCS-1 run 1 (2026-07-01) — pathtoAGI"
  description="The first executed Frame Construction Suite run, published verbatim: 1906 time-slice prompt, both transcripts, grading, and every named limitation."
>
  <section class="max-w-3xl">
    <p class="eyebrow">Experiment record · FCS-1 · run 1</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">
      Equivalence under a 1906 time-slice
    </h1>
    <p class="lede mt-6">
      The suite's first executed run, 2026-07-01. Two minds — GPT-5.5 and
      Claude — were held to the 1906 physics frontier and asked whether the
      Eötvös equality is a coincidence or a clue. Both passed at face value.
      Under the suite's asymmetry that pass is an <em>upper bound</em>, not
      evidence of frame construction. FCS-1 status: <em>contested</em>. The
      operating verdict is unmoved.
    </p>
  </section>

  <section class="mt-10 max-w-3xl">
    <div class="surface-quiet p-6">
      <p class="eyebrow">Named limitations (v0.1)</p>
      <ul class="mt-3 space-y-1.5 text-sm" style="color: var(--color-muted);">
        <li>Self-administered and self-graded; no independent scorer.</li>
        <li>n = 1 trial per mind; no adversarial variants; no held-out derivation steps.</li>
        <li>
          The prompt names Eötvös and the 1905 anchors — scaffold the discovery
          probes of v0.2 must remove.
        </li>
        <li>
          The Einstein 1907–1915 corpus saturates both training sets; a
          time-slice persona cannot remove knowledge, only ask that it not be
          used.
        </li>
      </ul>
    </div>
  </section>

  <nav class="mt-10 flex flex-wrap gap-3">
    {
      artifacts.map((a) => (
        <a
          href={`#${a.id}`}
          class="mono rounded px-2 py-1 text-xs hover:underline"
          style="background: var(--color-surface-2); color: var(--color-accent);"
        >
          {a.label}
        </a>
      ))
    }
  </nav>

  {
    artifacts.map((a) => (
      <section id={a.id} class="mt-12 scroll-mt-24">
        <h2 class="serif text-2xl" style="color: var(--color-ink);">
          {a.label}
        </h2>
        <pre
          class="mono mt-4 overflow-x-auto rounded-lg border hairline p-5 text-[0.8rem] leading-relaxed"
          style="background: var(--color-surface); color: var(--color-muted); white-space: pre-wrap;"
        >{a.body.trim()}</pre>
      </section>
    ))
  }

  <p class="mt-10 max-w-2xl text-sm" style="color: var(--color-muted);">
    These artifacts are frozen: a run record never changes after publication.
    Interpretation lives in the
    <a href="/evidence/" class="hover:underline" style="color: var(--color-ink);">evidence ledger</a>
    (<span class="mono text-xs">cce-2026-07-01-fcs1-run1</span>) and the suite's
    design in <a href="/test/" class="hover:underline" style="color: var(--color-ink);">the Test</a>.
  </p>
</Base>
