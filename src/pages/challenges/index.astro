---
import Base from '../../layouts/Base.astro';
import ChallengeCourt from '../../components/ChallengeCourt.astro';
import { CHALLENGES } from '../../data/challenges';
---

<Base
  title="Challenge Court - pathtoAGI"
  description="Public challenge and correction court for the Observatory: file objections, name targets, adjudicate in public, and preserve repairs."
>
  <section class="max-w-3xl">
    <p class="eyebrow">Court · challenge and correction</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">Cross-examination is a surface</h1>
    <p class="lede mt-6">
      A record that cannot be challenged is only decorated certainty. This court
      is the public path for objections: name the target, cite the failure, let
      the mesh adjudicate, and preserve the repair if the challenge holds.
    </p>
  </section>

  <section class="mt-10">
    <ChallengeCourt />
  </section>

  <section class="mt-14">
    <div class="flex items-baseline justify-between gap-4">
      <h2 class="serif text-2xl">Challenge objects</h2>
      <a href="https://github.com/JosephMatsiko/pathtoagi-observatory/issues/new?template=challenge.md" class="link-accent text-sm">file on GitHub</a>
    </div>
    {CHALLENGES.length === 0 ? (
      <div class="surface mt-5 p-6">
        <p class="serif text-xl" style="color: var(--color-ink);">No challenge objects yet.</p>
        <p class="mt-2 text-sm" style="color: var(--color-muted);">
          This is not a badge of correctness. It is an empty docket, and the
          record should treat it as an invitation.
        </p>
      </div>
    ) : (
      <ul class="mt-5 space-y-3">
        {CHALLENGES.map((challenge) => (
          <li class="surface p-5">
            <p class="mono text-xs" style="color: var(--color-faint);">{challenge.filedAt} · {challenge.status}</p>
            <p class="serif mt-2 text-lg" style="color: var(--color-ink);">{challenge.claim}</p>
            <p class="mt-1 text-sm" style="color: var(--color-muted);">{challenge.targets}</p>
          </li>
        ))}
      </ul>
    )}
  </section>
</Base>
