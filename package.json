{
  "name": "observatory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The Observatory — a lean, inspectable public record tracking the path to AGI.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "check:record": "node scripts/check-record.mjs",
    "maintain:status": "node scripts/maintenance-status.mjs",
    "loop:run": "node scripts/maintenance-status.mjs && node scripts/check-record.mjs",
    "loop:record": "node scripts/record-run.mjs",
    "archive:sources": "node scripts/archive-sources.mjs"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
