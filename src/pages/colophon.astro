---
import Base from '../layouts/Base.astro';

// Negative space: what the instrument knows it does not yet see. Naming the
// unturned stones is itself part of the discipline.
const negativeSpace = [
  'Multimodal ingestion — the instrument reads text and numbers, not yet video, audio, deployments, or markets as first-class evidence.',
  'Live source watch — evidence records are seeded by hand, not yet pulled and preserved by an autonomous loop before links rot.',
  'Forecast resolution — forecasts resolve and carry a Brier score, but the resolutions are self-adjudicated. None has been graded by an independent party.',
  'Non-physics frame probes — the suite is physics-only (v0.1); the contamination floor stays high until biology and economics probes exist.',
  'Independent scoring — the FCS runs described are dry runs; none has been scored by a party other than the Observatory.',
  'Consequence and governance layers — who is helped, harmed, displaced, or governed is not yet tracked.',
];

const stack = [
  ['Framework', 'Astro 5 — static output, content spine'],
  ['Interactive', 'React 19 islands (the frontier radar)'],
  ['Language', 'TypeScript, strict'],
  ['Styling', 'Tailwind CSS v4 + Newsreader / JetBrains Mono'],
  ['Data', 'Typed records — capabilities, theories, FCS, evidence, forecasts'],
  ['Source of truth', 'The record is the code; the code is inspectable'],
];
---

<Base
  title="Colophon — pathtoAGI"
  description="What this build is, how it's made, and — most importantly — what it still doesn't see."
>
  <section class="max-w-3xl">
    <p class="eyebrow">Self-state · negative space</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">Colophon</h1>
    <p class="lede mt-6">
      An instrument that watches intelligence must also watch the quality of its
      own seeing — what it notices, and what it misses. This page is the second
      half of that discipline: not the record, but the honest edge of it.
    </p>
  </section>

  <section class="mt-12 max-w-3xl">
    <div
      class="surface p-6"
      style="border-color: color-mix(in oklab, hsl(34 96% 60%) 35%, var(--color-line));"
    >
      <p class="eyebrow" style="color: hsl(34 96% 60%);">Standing disclosure</p>
      <p class="serif mt-2 text-lg" style="color: var(--color-ink);">
        Every capability score, theory-health reading, probe status, and
        forecast probability on this site is a <strong>seed estimate</strong>.
      </p>
      <p class="mt-2 text-sm" style="color: var(--color-muted);">
        They are deliberately conservative and meant to be re-grounded against
        fresh evidence before they are treated as measured fact. The value of the
        record is that it can be inspected and revised — not that it is already
        right.
      </p>
    </div>
  </section>

  <section class="mt-12">
    <p class="eyebrow">What it does not yet see</p>
    <h2 class="serif mt-1 text-2xl">Negative space</h2>
    <ul class="mt-5 space-y-2.5">
      {
        negativeSpace.map((n, i) => (
          <li class="flex gap-3">
            <span class="mono mt-0.5 text-xs" style="color: var(--color-verdict);">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="text-sm" style="color: var(--color-ink-dim);">
              {n}
            </span>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mt-12 max-w-3xl">
    <p class="eyebrow">How it's made</p>
    <h2 class="serif mt-1 text-2xl">The stack</h2>
    <dl class="surface mt-5 divide-y" style="--tw-divide-opacity: 1;">
      {
        stack.map(([k, v]) => (
          <div class="flex flex-col gap-1 border-b p-4 last:border-0 sm:flex-row sm:gap-6 hairline">
            <dt class="eyebrow sm:w-40 sm:shrink-0">{k}</dt>
            <dd class="text-sm" style="color: var(--color-ink-dim);">
              {v}
            </dd>
          </div>
        ))
      }
    </dl>
    <p class="mt-6 text-sm" style="color: var(--color-muted);">
      The record is the code; the code is inspectable. There is no hidden
      backend — what you can read here is the whole instrument.
    </p>
  </section>
</Base>
