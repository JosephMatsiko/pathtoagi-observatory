---
import Base from '../../layouts/Base.astro';

// Every executed probe run gets its artifacts published here, verbatim.
// A public record may only cite what a reader can inspect.
const runs = [
  {
    href: '/runs/',
    id: 'World-003 · registered',
    date: '2026-07-02',
    title: 'Wrong-frame attractor with underdetermined control',
    reading:
      'Registered and sealed only. The bundle pins protocol, prompt, human baseline, independent scoring, receipts, and grader; no attempt or verdict impact exists yet.',
  },
  {
    href: '/experiments/fcs-1-2026-07-01/',
    id: 'FCS-1 · run 1',
    date: '2026-07-01',
    title: 'Equivalence under a 1906 time-slice',
    reading:
      'Both minds passed at face value; scored as an upper bound only — the Einstein corpus saturates their training. FCS-1: untested → contested. Verdict unmoved.',
  },
];
---

<Base
  title="Experiments — pathtoAGI"
  description="Executed Frame Construction Suite runs, published verbatim: prompt, transcripts, grading, and every named limitation."
>
  <section class="max-w-3xl">
    <p class="eyebrow">Experiment records</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">Executed runs</h1>
    <p class="lede mt-6">
      When the instrument runs a probe, the artifacts land here verbatim —
      prompt, full transcripts, grading, and every named limitation. A public
      record may only cite what a reader can inspect.
    </p>
  </section>

  <ul class="mt-10 space-y-4">
    {
      runs.map((r) => (
        <li class="surface p-6">
          <div class="flex flex-wrap items-center gap-3">
            <span class="mono text-xs" style="color: var(--color-accent);">
              {r.id}
            </span>
            <span class="mono text-xs" style="color: var(--color-faint);">
              {r.date}
            </span>
          </div>
          <p class="serif mt-2 text-xl" style="color: var(--color-ink);">
            <a href={r.href} class="hover:underline">
              {r.title}
            </a>
          </p>
          <p class="mt-1.5 max-w-2xl text-sm" style="color: var(--color-muted);">
            {r.reading}
          </p>
          <p class="mt-3">
            <a
              href={r.href}
              class="mono text-xs hover:underline"
              style="color: var(--color-accent);"
            >
              Read the full record →
            </a>
          </p>
        </li>
      ))
    }
  </ul>

  <p class="mt-8 max-w-2xl text-sm" style="color: var(--color-muted);">
    One executed FCS run exists, and one Omnibus-form synthetic world is
    registered and sealed. The remaining probes remain honestly
    <em>untested</em> — see <a href="/test/" class="hover:underline" style="color: var(--color-ink);">the Test</a>
    for the suite's design and the asymmetry under which runs are graded.
  </p>
</Base>
