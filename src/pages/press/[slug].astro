---
import Base from '../../layouts/Base.astro';
import { DISPATCHES, DISPATCH_KIND_LABEL } from '../../data/dispatches';
import audioManifest from '../../data/audio-manifest.json';

export function getStaticPaths() {
  return DISPATCHES.map((d) => ({ params: { slug: d.slug }, props: { d } }));
}

const { d } = Astro.props;
const audio = (audioManifest as any[]).find((a) => a.slug === d.slug);
---

<Base title={`${d.title} — The Observatory Press`} description={d.standfirst} ogImage={`/og/press-${d.slug}.png`}>
  <article class="max-w-3xl">
    <p class="eyebrow">
      The Observatory Press · {DISPATCH_KIND_LABEL[d.kind]} No.{' '}
      {String(d.no).padStart(3, '0')} · {d.date}
    </p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">{d.title}</h1>
    <p class="lede mt-6">{d.standfirst}</p>

    {
      audio && (
        <div class="surface-quiet mt-8 p-5">
          <p class="eyebrow">Audio edition</p>
          <audio controls preload="none" class="mt-3 w-full" src={audio.file}></audio>
          <p class="mono mt-2 text-xs" style="color: var(--color-faint);">
            Synthetic narration ({audio.voice}), generated by the instrument
            itself. The written record is canonical.
          </p>
        </div>
      )
    }

    <div class="prose mt-10 space-y-5">
      {d.body.map((p) => <p>{p}</p>)}
    </div>

    {
      d.plain && (
        <section class="mt-10 surface-quiet p-6">
          <p class="eyebrow">Plain reading</p>
          <div class="mt-3 space-y-3 text-sm" style="color: var(--color-ink-dim);">
            {d.plain.map((p) => (
              <p>{p}</p>
            ))}
          </div>
        </section>
      )
    }

    <section class="mt-12 surface-quiet p-6">
      <p class="eyebrow">Record references</p>
      <p class="mt-2 text-sm" style="color: var(--color-muted);">
        Every claim above derives from the public record. This dispatch is
        frozen; corrections happen in the
        <a href="/log/" class="link-accent">revision log</a>.
      </p>
      <ul class="mono mt-3 space-y-1 text-xs" style="color: var(--color-faint);">
        {d.recordRefs.map((r) => <li>· {r}</li>)}
      </ul>
    </section>
  </article>
</Base>
