---
import Base from '../../layouts/Base.astro';
import Frontier from '../../components/Frontier.tsx';
import {
  CAPABILITY_AXES,
  FRONTIER_2026,
  HUMAN_REFERENCE,
} from '../../data/capabilities';

const rows = CAPABILITY_AXES.map((axis) => ({
  axis,
  frontier: FRONTIER_2026[axis.id],
  human: HUMAN_REFERENCE[axis.id],
  gap: HUMAN_REFERENCE[axis.id] - FRONTIER_2026[axis.id],
})).sort((a, b) => b.gap - a.gap);
const maxGap = Math.max(...rows.map((r) => r.gap));
---

<Base
  title="The capability frontier — The Observatory"
  description="Eight capability axes scored 0–1: the 2026 frontier estimate against a human-competent reference, ranked by the gap that remains."
>
  <section class="max-w-3xl">
    <p class="eyebrow">Instrument · eight axes</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">The capability frontier</h1>
    <p class="lede mt-6">
      Eight axes chosen to slice "AGI" along the dimensions Demis Hassabis names
      as gaps. Each is scored 0–1: 0.7 is robust within a single substrate, 1.0
      is human-level breadth and reliability.
    </p>
    <p class="mt-4 text-sm" style="color: var(--color-muted);">
      The values are an Observatory seed estimate for 2026 — deliberately
      conservative, meant to be revised against evidence, not treated as
      measured fact. See the <a href="/colophon/" class="link-accent">colophon</a>.
    </p>
  </section>

  <div class="surface mt-10 p-5 sm:p-8">
    <Frontier client:load />
  </div>

  <section class="mt-14">
    <h2 class="serif text-2xl">Ranked by remaining gap</h2>
    <div class="surface mt-4 overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr
            class="border-b hairline text-left"
          >
            <th class="eyebrow px-4 py-3 font-normal">Axis</th>
            <th class="eyebrow px-4 py-3 font-normal">Frontier</th>
            <th class="eyebrow px-4 py-3 font-normal">Human</th>
            <th class="eyebrow px-4 py-3 font-normal">Gap</th>
          </tr>
        </thead>
        <tbody>
          {
            rows.map(({ axis, frontier, human, gap }) => (
              <tr class="border-b hairline last:border-0">
                <td class="px-4 py-3 align-top">
                  <span
                    class="mr-2 inline-block h-2 w-2 rounded-full align-middle"
                    style={`background: ${axis.accent};`}
                  />
                  <span class="align-middle serif" style="color: var(--color-ink);">
                    {axis.label}
                  </span>
                  <div class="mt-0.5 text-xs" style="color: var(--color-muted);">
                    {axis.description}
                  </div>
                </td>
                <td class="tabular px-4 py-3 align-top">{frontier.toFixed(2)}</td>
                <td
                  class="tabular px-4 py-3 align-top"
                  style="color: var(--color-faint);"
                >
                  {human.toFixed(2)}
                </td>
                <td class="px-4 py-3 align-top">
                  <div class="flex items-center gap-2">
                    <div
                      class="h-1.5 w-16 overflow-hidden rounded-full"
                      style="background: var(--color-surface-2);"
                    >
                      <div
                        class="h-full rounded-full"
                        style={`width: ${Math.round((gap / maxGap) * 100)}%; background: ${axis.accent};`}
                      />
                    </div>
                    <span class="tabular text-xs">{gap.toFixed(2)}</span>
                  </div>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <p class="prose mt-8 max-w-3xl">
    The largest gaps — embodiment, memory, world models, creativity — are the
    same absences the <a href="/theories/architectural-gap/" class="link-accent"
      >architectural-gap</a
    > and <a href="/theories/embodiment-required/" class="link-accent"
      >embodiment-required</a
    > theories name. The frontier's strong axes are where scaling has already
    paid out. The missing bar is the same one the <a href="/test/" class="link-accent"
      >Einstein Test</a
    > measures: reliable frame construction under sparse evidence.
  </p>
</Base>
