{
  "name": "observatory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The Observatory — a lean, inspectable public record tracking the path to AGI.",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/sync-public-experiments.mjs && node scripts/build-dataset.mjs && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "check:record": "node scripts/check-record.mjs",
    "maintain:status": "node scripts/maintenance-status.mjs",
    "loop:run": "node scripts/maintenance-status.mjs && node scripts/check-record.mjs",
    "loop:record": "node scripts/record-run.mjs",
    "archive:sources": "node scripts/archive-sources.mjs",
    "timestamp:record": "node scripts/timestamp-record.mjs",
    "check:timestamps": "node scripts/check-timestamps.mjs",
    "media:narrate": "node scripts/narrate-dispatches.mjs",
    "media:og": "node scripts/og-images.mjs",
    "media:build": "npm run media:narrate && npm run media:og && npm run media:llms",
    "media:llms": "node scripts/llms-full.mjs",
    "sync:experiments": "node scripts/sync-public-experiments.mjs",
    "deploy": "netlify deploy --prod --dir=dist --functions=netlify/functions --site=0a12a26b-a57b-41fe-933a-fa66e54ea03a",
    "ship": "npm run check:record && npm run build && npm run deploy"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "opentimestamps": "^0.4.9",
    "sharp": "^0.35.3",
    "typescript": "^5.7.0"
  }
}
