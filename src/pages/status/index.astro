---
import Base from '../../layouts/Base.astro';
import { EVIDENCE } from '../../data/evidence';
import { FORECASTS, calibration } from '../../data/forecasts';
import { RUNS } from '../../data/runs';
import {
  METHOD_HEALTH,
  METHOD_STATUS_COLOR,
  METHOD_STATUS_LABEL,
} from '../../data/method-health';
import {
  INCIDENTS,
  INCIDENT_STATUS_COLOR,
  INCIDENT_STATUS_LABEL,
} from '../../data/incidents';
import { CHALLENGES } from '../../data/challenges';
import { CORRESPONDENCE } from '../../data/correspondence';
import { RUN_BUNDLES } from '../../data/run-bundles';

const today = new Date().toISOString().slice(0, 10);
const daysAgo = (d: string) =>
  Math.max(0, Math.round((Date.parse(today) - Date.parse(d)) / 86_400_000));

const lastEvidence = [...EVIDENCE].map((e) => e.observedAt).sort().at(-1) ?? null;
const lastRun = [...RUNS].sort((a, b) => b.at.localeCompare(a.at))[0];
const cal = calibration(FORECASTS);
const due = FORECASTS.filter((f) => f.status === 'open' && f.horizonDate <= today);
const openChallenges = CHALLENGES.filter((c) => c.status === 'open');
const openIncidents = INCIDENTS.filter((i) => i.status === 'open');
const containedIncidents = INCIDENTS.filter((i) => i.status === 'contained');
const activeMethodIssues = METHOD_HEALTH.filter((m) => m.status !== 'ok');

const statusColor =
  openIncidents.length > 0 || due.length > 0
    ? 'var(--color-verdict)'
    : containedIncidents.length > 0 || activeMethodIssues.length > 0
      ? 'hsl(34 96% 60%)'
      : 'var(--color-affirm)';
const statusLabel =
  openIncidents.length > 0
    ? 'Repair required'
    : due.length > 0
      ? 'Judgment due'
      : containedIncidents.length > 0
        ? 'Contained'
        : 'Operating';
---

<Base
  title="Status - pathtoAGI"
  description="Public operating status for the Observatory: record freshness, calibration, incidents, challenges, method health, and reproduction readiness."
>
  <section class="max-w-3xl">
    <p class="eyebrow">Status · public operating readout</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">The instrument's state</h1>
    <p class="lede mt-6">
      A compact status surface for the record itself: what is fresh, what is
      due, what broke, what was repaired, and what remains under watch. Public
      status is evidence-bound, not mood-bound.
    </p>
  </section>

  <section
    class="mt-10 surface p-6"
    style={`border-color: color-mix(in oklab, ${statusColor} 42%, var(--color-line));`}
  >
    <div class="flex flex-wrap items-center gap-4">
      <span class="pulse" aria-hidden="true" style={`background: ${statusColor};`}></span>
      <div>
        <p class="eyebrow">Current state</p>
        <p class="serif text-3xl" style={`color: ${statusColor};`}>{statusLabel}</p>
      </div>
      <div class="ml-auto text-right">
        <p class="mono text-xs" style="color: var(--color-faint);">as of {today}</p>
        <p class="mono text-xs" style="color: var(--color-faint);">
          last run {lastRun?.at ?? 'none recorded'}
        </p>
      </div>
    </div>
  </section>

  <section class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <div class="surface-quiet p-5">
      <p class="eyebrow">Record freshness</p>
      <p class="tabular mt-2 text-3xl" style="color: var(--color-ink);">
        {lastEvidence ? daysAgo(lastEvidence) : '—'}<span class="text-base" style="color: var(--color-faint);">d</span>
      </p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">
        last evidence {lastEvidence ?? 'none'}
      </p>
    </div>
    <div class="surface-quiet p-5">
      <p class="eyebrow">Calibration</p>
      <p class="tabular mt-2 text-3xl" style="color: var(--color-affirm);">
        {cal.meanBrier !== null ? cal.meanBrier.toFixed(3) : '—'}
      </p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">
        mean Brier over {cal.resolvedCount} live resolved forecasts
      </p>
    </div>
    <div class="surface-quiet p-5">
      <p class="eyebrow">Due judgments</p>
      <p class="tabular mt-2 text-3xl" style={`color: ${due.length ? 'var(--color-verdict)' : 'var(--color-ink)'};`}>
        {due.length}
      </p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">
        forecasts past horizon
      </p>
    </div>
    <div class="surface-quiet p-5">
      <p class="eyebrow">Reproduction surface</p>
      <p class="tabular mt-2 text-3xl" style="color: var(--color-accent);">
        {RUN_BUNDLES.length}
      </p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">
        Omnibus run bundle{RUN_BUNDLES.length === 1 ? '' : 's'}
      </p>
    </div>
  </section>

  <section class="mt-14 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
    <div>
      <div class="flex items-baseline justify-between gap-4">
        <h2 class="serif text-2xl">Incidents</h2>
        <a href="/record.json" class="link-accent text-sm">record.json</a>
      </div>
      <p class="mt-2 text-sm" style="color: var(--color-muted);">
        Omnibus adoption makes failure objects part of the record. Resolved
        incidents remain visible because repair without memory is drift.
      </p>
      <ul class="mt-5 space-y-3">
        {
          INCIDENTS.map((incident) => (
            <li class="surface p-5">
              <div class="flex flex-wrap items-center gap-3">
                <span class="mono text-xs" style="color: var(--color-faint);">
                  {incident.date}
                </span>
                <span
                  class="mono rounded px-1.5 py-0.5 text-[0.62rem] uppercase tracking-wider"
                  style={`background: var(--color-surface-2); color: ${INCIDENT_STATUS_COLOR[incident.status]};`}
                >
                  {INCIDENT_STATUS_LABEL[incident.status]}
                </span>
                <span class="mono text-xs" style="color: var(--color-muted);">
                  {incident.category} · {incident.severity}
                </span>
              </div>
              <p class="serif mt-3 text-lg" style="color: var(--color-ink);">
                {incident.summary}
              </p>
              <p class="mt-2 text-sm" style="color: var(--color-muted);">
                {incident.nextControl}
              </p>
            </li>
          ))
        }
      </ul>
    </div>

    <aside class="space-y-4">
      <div class="surface p-5">
        <p class="eyebrow">Challenges</p>
        <p class="tabular mt-2 text-3xl" style={`color: ${openChallenges.length ? 'var(--color-verdict)' : 'var(--color-ink)'};`}>
          {openChallenges.length}
        </p>
        <p class="mt-1 text-sm" style="color: var(--color-muted);">
          open of {CHALLENGES.length} all-time challenge objects
        </p>
      </div>
      <div class="surface p-5">
        <p class="eyebrow">Method health</p>
        <ul class="mt-4 space-y-3">
          {
            METHOD_HEALTH.map((m) => (
              <li>
                <div class="flex items-center gap-3">
                  <span class="text-sm" style="color: var(--color-ink-dim);">{m.method}</span>
                  <span
                    class="mono ml-auto text-[0.62rem] uppercase tracking-wider"
                    style={`color: ${METHOD_STATUS_COLOR[m.status]};`}
                  >
                    {METHOD_STATUS_LABEL[m.status]}
                  </span>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="surface p-5">
        <p class="eyebrow">Omnibus adoption</p>
        <p class="mt-2 text-sm" style="color: var(--color-muted);">
          Source, adoption map, threat model, doctrines, and incident objects
          are now part of the governed record. Tranche two adds the first
          registered sealed run bundle.
        </p>
        <p class="mt-3 flex flex-wrap gap-3">
          <a href="https://github.com/JosephMatsiko/pathtoagi-observatory/blob/main/docs/OMNIBUS_V2_SOURCE.md" class="mono text-xs link-accent">source</a>
          <a href="https://github.com/JosephMatsiko/pathtoagi-observatory/blob/main/docs/OMNIBUS_V2_ADOPTION.md" class="mono text-xs link-accent">adoption</a>
          <a href="/runs/" class="mono text-xs link-accent">runs</a>
          <a href="/reproduce/" class="mono text-xs link-accent">reproduce</a>
        </p>
      </div>
      <div class="surface p-5">
        <p class="eyebrow">External channels</p>
        <p class="tabular mt-2 text-3xl" style="color: var(--color-accent);">
          {CORRESPONDENCE.length}
        </p>
        <p class="mt-1 text-sm" style="color: var(--color-muted);">
          correspondence objects on record
        </p>
      </div>
    </aside>
  </section>
</Base>
