---
import Base from '../../layouts/Base.astro';
import { CYCLES } from '../../data/cycles';

const cycles = [...CYCLES].sort((a, b) => b.shippedAt.localeCompare(a.shippedAt));
const fileLabel: Record<string, string> = {
  'proposal.md': 'Scout proposal',
  'verdict.md': 'Adversary verdict',
  'calibration.md': 'Calibrator grading',
  'trace.json': 'Cycle trace',
};
---

<Base
  title="Published cycles — pathtoAGI"
  description="Every shipped maintenance cycle's working artifacts, verbatim: the Scout's proposal, the Adversary's verdict, the Calibrator's grading, the trace. Any change to the record can be traced from raw claim to adversarial review to ship."
>
  <section class="max-w-3xl">
    <p class="eyebrow">Provenance · the mesh, in public</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">Published cycles</h1>
    <p class="lede mt-6">
      The record is maintained by an adversarial mesh of three model families.
      When a cycle ships a change, its working artifacts are published here
      verbatim — the proposal, the independent adversary's verdict, the
      calibration grading, the trace — so any claim on the record can be traced
      from raw draft to adversarial review to ship. Disagreement is part of the
      record, not something edited out of it.
    </p>
  </section>

  <ul class="mt-10 space-y-4">
    {
      cycles.map((c) => (
        <li class="surface p-6">
          <div class="flex flex-wrap items-center gap-3">
            <span class="mono text-xs" style="color: var(--color-accent);">
              {c.id}
            </span>
            <span class="mono text-xs" style="color: var(--color-faint);">
              shipped {c.shippedAt}
            </span>
            <span
              class="mono rounded px-1.5 py-0.5 text-[0.62rem] uppercase tracking-wider"
              style="background: var(--color-surface-2); color: hsl(8 84% 64%);"
            >
              adversary: {c.adversary}
            </span>
            {!c.files.includes('calibration.md') && (
              <span
                class="mono rounded px-1.5 py-0.5 text-[0.62rem] uppercase tracking-wider"
                style="background: var(--color-surface-2); color: hsl(34 96% 60%);"
              >
                calibration lane absent
              </span>
            )}
          </div>
          <p class="mt-2 text-sm" style="color: var(--color-muted);">
            {c.summary}
          </p>
          <p class="mt-3 flex flex-wrap gap-3">
            {c.files.map((f) => (
              <a
                href={`/cycles/${c.id}/${f}`}
                class="mono text-xs hover:underline"
                style="color: var(--color-accent);"
              >
                {fileLabel[f] ?? f} →
              </a>
            ))}
          </p>
        </li>
      ))
    }
  </ul>

  <p class="mt-8 max-w-2xl text-sm" style="color: var(--color-muted);">
    Artifacts are frozen at ship time and published from the shipping cycle
    forward ({cycles.length} so far). Lanes write for the record: no secrets, no
    private material — the gate and the mesh's mandates both bind them to that.
  </p>
</Base>
