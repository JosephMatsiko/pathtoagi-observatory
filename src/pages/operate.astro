---
import Base from '../layouts/Base.astro';
import { FORECASTS, calibration, brierOf } from '../data/forecasts';
import { EVIDENCE } from '../data/evidence';
import { RUNS } from '../data/runs';
import {
  METHOD_HEALTH,
  METHOD_STATUS_LABEL,
  METHOD_STATUS_COLOR,
} from '../data/method-health';

const today = new Date().toISOString().slice(0, 10);
const daysAgo = (d: string) =>
  Math.round((Date.parse(today) - Date.parse(d)) / 86_400_000);

const cal = calibration(FORECASTS);
const due = FORECASTS.filter((f) => f.status === 'open' && f.horizonDate <= today);
const lastEvidence = [...EVIDENCE].map((e) => e.observedAt).sort().at(-1) ?? '—';
const evAge = lastEvidence === '—' ? Infinity : daysAgo(lastEvidence);
const lastRun = [...RUNS].sort((a, b) => b.at.localeCompare(a.at))[0];
const runs = [...RUNS].sort((a, b) => b.at.localeCompare(a.at));

// Brier over resolved forecasts, oldest → newest, for the trend row.
const resolvedSeries = FORECASTS.filter((f) => f.status !== 'open')
  .sort((a, b) => (a.resolvedAt ?? '').localeCompare(b.resolvedAt ?? ''))
  .map((f) => ({ f, brier: brierOf(f)! }));

const toImprove = METHOD_HEALTH.filter((m) => m.status === 'act').length;
---

<Base
  title="Control room — pathtoAGI"
  description="Observe and operate the maintenance loop: live calibration, the resolution queue, run history, and the instrument's own method health."
>
  <section class="max-w-3xl">
    <p class="eyebrow">Control room · observe + operate</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">Operate the instrument</h1>
    <p class="lede mt-6">
      The space to watch the loop work — and to run it. Everything here is the
      loop's real state: what it has done, what is due, how well-calibrated it
      is, and where its own instruments are decaying. Composed agency under
      evidence, kept under your hand.
    </p>
  </section>

  <!-- Loop state -->
  <section
    class="mt-10 surface p-6"
    style="border-color: color-mix(in oklab, var(--color-accent) 30%, var(--color-line));"
  >
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <span class="pulse" aria-hidden="true"></span>
        <div>
          <p class="eyebrow">Loop state</p>
          <p class="serif text-lg" style="color: var(--color-ink);">
            Designed & gated · schedule off · runs on Claude Max
          </p>
        </div>
      </div>
      <div class="text-right">
        <p class="mono text-xs" style="color: var(--color-faint);">
          last run {lastRun?.at}
        </p>
        <p class="mono text-xs" style="color: var(--color-faint);">
          {due.length} due · {toImprove} methods to improve
        </p>
      </div>
    </div>
  </section>

  <!-- Live readouts -->
  <section class="mt-4 grid gap-4 sm:grid-cols-3">
    <div class="surface-quiet p-5">
      <p class="eyebrow">Calibration · mean Brier</p>
      <p class="tabular mt-2 text-3xl" style="color: var(--color-affirm);">
        {cal.meanBrier !== null ? cal.meanBrier.toFixed(3) : '—'}
      </p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">
        over {cal.resolvedCount} resolved · baseline 0.25
      </p>
    </div>
    <div class="surface-quiet p-5">
      <p class="eyebrow">Record freshness</p>
      <p
        class="tabular mt-2 text-3xl"
        style={`color: ${evAge > 14 ? 'var(--color-verdict)' : 'var(--color-ink)'};`}
      >
        {evAge}<span class="text-base" style="color: var(--color-faint);">d</span>
      </p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">
        since last evidence · {lastEvidence}
      </p>
    </div>
    <div class="surface-quiet p-5">
      <p class="eyebrow">Resolution queue</p>
      <p class="tabular mt-2 text-3xl" style="color: var(--color-ink);">
        {due.length}
      </p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">
        forecasts past horizon, awaiting judgment
      </p>
    </div>
  </section>

  <!-- Calibration trend -->
  <section class="mt-12">
    <h2 class="serif text-2xl">Calibration, resolved</h2>
    <p class="mt-1 text-sm" style="color: var(--color-muted);">
      Each resolved forecast's Brier contribution — shorter is better. The misses
      stay on the record.
    </p>
    <ul class="mt-5 space-y-2.5">
      {
        resolvedSeries.map(({ f, brier }) => (
          <li class="flex items-center gap-3">
            <span class="mono w-24 shrink-0 text-xs" style="color: var(--color-faint);">
              {f.resolvedAt}
            </span>
            <div class="h-2 flex-1 overflow-hidden rounded-full" style="background: var(--color-surface-2);">
              <div
                class="h-full rounded-full"
                style={`width: ${Math.max(3, Math.round((brier / 0.25) * 100))}%; background: ${brier < 0.1 ? 'var(--color-affirm)' : brier < 0.25 ? 'hsl(34 96% 60%)' : 'var(--color-verdict)'};`}
              />
            </div>
            <span class="tabular w-12 shrink-0 text-right text-xs" style="color: var(--color-ink-dim);">
              {brier.toFixed(3)}
            </span>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- The due queue -->
  <section class="mt-12">
    <h2 class="serif text-2xl">Resolution queue</h2>
    {
      due.length === 0 ? (
        <p class="mt-3 text-sm" style="color: var(--color-muted);">
          Nothing past its horizon. The loop has no forecasts awaiting judgment
          as of {today}.
        </p>
      ) : (
        <ul class="mt-4 space-y-2">
          {due.map((f) => (
            <li class="surface-quiet flex flex-wrap items-baseline gap-x-3 gap-y-1 p-4">
              <span class="mono text-xs" style="color: var(--color-verdict);">
                due {f.horizonDate}
              </span>
              <span class="text-sm" style="color: var(--color-ink-dim);">
                {f.claim}
              </span>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <!-- Method health — self-improvement -->
  <section class="mt-12">
    <div class="flex items-baseline justify-between gap-4">
      <div>
        <p class="eyebrow">Recursive, bounded · the instrument on itself</p>
        <h2 class="serif mt-1 text-2xl">Method health</h2>
      </div>
    </div>
    <p class="mt-2 max-w-2xl text-sm" style="color: var(--color-muted);">
      The honest form of self-improvement: not the intelligence rewriting its own
      mind, but the instrument watching where its own probes, axes, and
      calibration are decaying — and naming the next improvement. Every change
      stays gated and reviewable.
    </p>
    <ul class="mt-5 space-y-3">
      {
        METHOD_HEALTH.map((m) => (
          <li class="surface p-5">
            <div class="flex flex-wrap items-center gap-3">
              <span class="serif text-lg" style="color: var(--color-ink);">
                {m.method}
              </span>
              <span
                class="mono ml-auto inline-flex items-center gap-1.5 rounded px-2 py-0.5 text-[0.62rem] uppercase tracking-wider"
                style={`background: var(--color-surface-2); color: ${METHOD_STATUS_COLOR[m.status]};`}
              >
                <span
                  class="inline-block h-1.5 w-1.5 rounded-full"
                  style={`background: ${METHOD_STATUS_COLOR[m.status]};`}
                />
                {METHOD_STATUS_LABEL[m.status]}
              </span>
            </div>
            <p class="mt-2 text-sm" style="color: var(--color-ink-dim);">
              {m.reading}
            </p>
            <p class="mt-2 text-sm" style="color: var(--color-muted);">
              <span class="eyebrow" style={`color: ${METHOD_STATUS_COLOR[m.status]};`}>
                Next improvement
              </span>
              <span class="ml-2">{m.nextImprovement}</span>
            </p>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Run history -->
  <section class="mt-12">
    <h2 class="serif text-2xl">Run history</h2>
    <ol class="mt-5 space-y-0">
      {
        runs.map((r, i) => (
          <li class="grid grid-cols-[auto_1fr] gap-5">
            <div class="flex flex-col items-center">
              <span
                class="mt-1.5 inline-block h-2.5 w-2.5 shrink-0 rounded-full"
                style={`background: ${r.gatePassed ? 'var(--color-affirm)' : 'var(--color-verdict)'};`}
              />
              {i < runs.length - 1 && (
                <span class="w-px flex-1" style="background: var(--color-line); min-height: 2rem;" />
              )}
            </div>
            <div class="pb-7">
              <div class="flex flex-wrap items-center gap-3">
                <span class="mono text-xs" style="color: var(--color-faint);">
                  {r.at}
                </span>
                <span
                  class="mono rounded px-1.5 py-0.5 text-[0.62rem] uppercase tracking-wider"
                  style="background: var(--color-surface-2); color: var(--color-muted);"
                >
                  {r.trigger}
                </span>
                <span class="mono text-xs" style="color: var(--color-faint);">
                  {r.actor}
                </span>
                {r.gatePassed && (
                  <span class="mono text-xs" style="color: var(--color-affirm);">
                    gate ✓
                  </span>
                )}
              </div>
              <ul class="mt-2 space-y-1">
                {r.actions.map((a) => (
                  <li class="text-sm" style="color: var(--color-ink-dim);">
                    — {a}
                  </li>
                ))}
              </ul>
              <p class="mt-1.5 text-sm" style="color: var(--color-muted);">
                {r.note}
              </p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- Operator console -->
  <section class="mt-12">
    <h2 class="serif text-2xl">Operator console</h2>
    <p class="mt-1 max-w-2xl text-sm" style="color: var(--color-muted);">
      The loop runs on your Claude Max subscription through Claude Code — as you,
      not a metered key. These are the controls.
    </p>
    <div
      class="mt-5 surface overflow-hidden p-5 font-mono text-sm"
      style="background: var(--color-void);"
    >
      <p style="color: var(--color-faint);"># orient — what needs doing</p>
      <p style="color: var(--color-affirm);">
        $ <span style="color: var(--color-ink);">npm run maintain:status</span>
      </p>
      <p class="mt-3" style="color: var(--color-faint);"># run a cycle (deterministic wrap + log)</p>
      <p style="color: var(--color-affirm);">
        $ <span style="color: var(--color-ink);">npm run loop:run</span>
      </p>
      <p class="mt-3" style="color: var(--color-faint);"># gate the record before commit</p>
      <p style="color: var(--color-affirm);">
        $ <span style="color: var(--color-ink);">npm run check:record</span>
      </p>
      <p class="mt-3" style="color: var(--color-faint);">
        # judgment step — in Claude Code, on your Max plan:
      </p>
      <p style="color: var(--color-muted);">
        &gt; "Run a maintenance cycle. Follow MAINTENANCE.md."
      </p>
    </div>
    <p class="mt-4 text-sm" style="color: var(--color-muted);">
      To run unattended, a scheduled Claude Code routine fires the same
      instruction on a cadence. The loop opens changes for review — it never
      merges itself. See <a href="/colophon/" class="link-accent">the colophon</a>
      and <span class="mono">MAINTENANCE.md</span>.
    </p>
  </section>
</Base>
