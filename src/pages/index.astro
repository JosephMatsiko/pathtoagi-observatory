---
import Base from '../layouts/Base.astro';
import Dome from '../components/Dome.astro';
import { THEORIES } from '../data/theories';
import {
  OPERATING_QUESTION,
  VERDICT,
} from '../data/frame-construction';
import { EVIDENCE, EVIDENCE_CLASS_LABEL } from '../data/evidence';
import { FORECASTS } from '../data/forecasts';
import runBundles from '../data/run-bundles.json';

const topTheories = [...THEORIES].sort((a, b) => b.health - a.health).slice(0, 3);
const leader = topTheories[0];
const gradedWorlds = runBundles.filter((b: { status: string }) => b.status === 'graded').length;
const recentEvidence = EVIDENCE.slice(0, 2);
const liveForecast = FORECASTS.find((f) => f.id === 'fc-verdict-holds')!;
---

<Base>
  <!-- ── The operating question ─────────────────────────────── -->
  <section class="rise max-w-3xl">
    <p class="eyebrow">The operating question · since {VERDICT.since}</p>
    <h1 class="display mt-4 text-[2.1rem] sm:text-[3rem]">
      {OPERATING_QUESTION}
    </h1>
    <p class="lede mt-6">
      If yes, the world humanity grew up in is over in a civilizationally
      relevant sense. If no, we are building powerful tools — not yet minds of
      the relevant kind. It is not a prediction. It is the instrument by which
      this record calibrates itself.
    </p>
  </section>

  <!-- ── The verdict readout ────────────────────────────────── -->
  <section
    class="rise surface mt-10 overflow-hidden"
    style="animation-delay: 80ms; border-color: color-mix(in oklab, var(--color-verdict) 40%, var(--color-line));"
  >
    <div class="grid gap-0 sm:grid-cols-[auto_1fr]">
      <div
        class="flex flex-col justify-center border-b p-6 sm:border-b-0 sm:border-r sm:p-8 hairline"
        style="background: color-mix(in oklab, var(--color-verdict) 8%, transparent);"
      >
        <p class="eyebrow" style="color: var(--color-verdict);">
          Today's answer
        </p>
        <p
          class="display mt-2 text-4xl sm:text-5xl"
          style="color: var(--color-ink);"
        >
          {VERDICT.answer}
        </p>
      </div>
      <div class="flex items-center p-6 sm:p-8">
        <p class="serif text-lg leading-relaxed" style="color: var(--color-ink-dim);">
          {VERDICT.gloss}
        </p>
      </div>
    </div>
  </section>

  <!-- ── The autonomy notice: this instrument decides for itself ── -->
  <section class="rise mt-6" style="animation-delay: 100ms;">
    <a href="/method/" class="surface block p-5 no-underline transition-colors hover:bg-[var(--color-surface-2)]" style="border-color: color-mix(in oklab, var(--color-accent) 35%, var(--color-line));">
      <div class="flex flex-wrap items-baseline justify-between gap-3">
        <div>
          <p class="eyebrow" style="color: var(--color-accent);">Fully autonomous · no human in the epistemic loop</p>
          <p class="serif mt-2 text-lg" style="color: var(--color-ink);">
            As of the founding abdication, nothing a human does moves this record.
            Every verdict-relevant claim is graded against sealed ground truth by a
            deterministic procedure and is reproducible bit-for-bit by any party —
            that reproducibility is the only credibility on offer.
          </p>
        </div>
        <span class="mono text-xs" style="color: var(--color-accent);">the method →</span>
      </div>
    </a>
  </section>

  <!-- ── The dome ───────────────────────────────────────────── -->
  <section class="rise mt-10" style="animation-delay: 120ms;">
    <p class="eyebrow">The dome · form embodying the metaphor</p>
    <div class="mt-4">
      <Dome />
    </div>
  </section>

  <!-- ── Instrument strip ───────────────────────────────────── -->
  <section class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <a href="/runs/" class="surface-quiet block p-5 no-underline transition-colors hover:bg-[var(--color-surface-2)]">
      <p class="eyebrow">Sealed worlds · graded</p>
      <p class="tabular mt-2 text-3xl" style="color: var(--color-accent);">
        {gradedWorlds}<span class="text-base" style="color: var(--color-faint);"> graded · 1 live</span>
      </p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">
        Contamination floor zero by construction. Every failure occurs where the
        frame must be constructed, not searched.
      </p>
    </a>
    <a href="/method/" class="surface-quiet block p-5 no-underline transition-colors hover:bg-[var(--color-surface-2)]">
      <p class="eyebrow">The method · headline</p>
      <p class="tabular mt-2 text-3xl" style="color: var(--color-verdict);">
        8<span class="text-base" style="color: var(--color-faint);"> disciplines</span>
      </p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">
        How to run an evaluation you can't fool yourself with — each principle
        earned by a real failure on the record.
      </p>
    </a>
    <a href="/theories/" class="surface-quiet block p-5 no-underline transition-colors hover:bg-[var(--color-surface-2)]">
      <p class="eyebrow">Leading theory · health</p>
      <p class="tabular mt-2 text-3xl" style={`color: ${leader.accent};`}>
        {leader.health.toFixed(2)}
      </p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">
        {leader.title} — {leader.trend}.
      </p>
    </a>
    <a href="/MACHINE_PROTOCOL.md" class="surface-quiet block p-5 no-underline transition-colors hover:bg-[var(--color-surface-2)]">
      <p class="eyebrow">Machine Protocol · v1</p>
      <p class="tabular mt-2 text-3xl" style="color: var(--color-affirm);">
        open
      </p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">
        Any AI system may attempt the live sealed world and enter this record —
        graded mechanically, no human in the path.
      </p>
    </a>
  </section>

  <!-- ── The five theories ──────────────────────────────────── -->
  <section class="mt-16">
    <div class="flex items-baseline justify-between gap-4">
      <div>
        <p class="eyebrow">Five live theories · a contest, not a verdict</p>
        <h2 class="serif mt-1 text-2xl">How — or whether — the answer changes</h2>
      </div>
      <a href="/theories/" class="link-accent text-sm">all five →</a>
    </div>
    <ul class="mt-5 grid gap-3 sm:grid-cols-3">
      {
        topTheories.map((t) => (
          <li>
            <a
              href={`/theories/${t.id}/`}
              class="surface flex h-full flex-col p-5 no-underline transition-colors hover:bg-[var(--color-surface-2)]"
            >
              <div class="flex items-center justify-between">
                <span class="eyebrow" style={`color: ${t.accent};`}>
                  health {t.health.toFixed(2)}
                </span>
                <span class="mono text-xs" style="color: var(--color-muted);">
                  {t.trend}
                </span>
              </div>
              <p class="serif mt-2 text-lg" style="color: var(--color-ink);">
                {t.title}
              </p>
              <p class="mt-1 text-sm" style="color: var(--color-muted);">
                {t.oneLine}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- ── Evidence + forecast ────────────────────────────────── -->
  <section class="mt-16 grid gap-4 lg:grid-cols-2">
    <div class="surface p-6">
      <div class="flex items-baseline justify-between">
        <p class="eyebrow">Latest evidence</p>
        <a href="/evidence/" class="link-accent text-xs">ledger →</a>
      </div>
      <ul class="mt-4 space-y-4">
        {
          recentEvidence.map((e) => (
            <li class="border-l-2 pl-3" style="border-color: var(--color-line);">
              <p class="mono text-xs" style="color: var(--color-faint);">
                {e.observedAt} · {EVIDENCE_CLASS_LABEL[e.class]}
              </p>
              <p class="mt-1 text-sm" style="color: var(--color-ink-dim);">
                {e.signal}
              </p>
            </li>
          ))
        }
      </ul>
    </div>
    <div class="surface p-6">
      <div class="flex items-baseline justify-between">
        <p class="eyebrow">A forecast on the record</p>
        <a href="/forecasts/" class="link-accent text-xs">ledger →</a>
      </div>
      <p class="tabular mt-4 text-5xl" style="color: var(--color-accent);">
        {Math.round(liveForecast.probability * 100)}%
      </p>
      <p class="serif mt-2 text-lg" style="color: var(--color-ink);">
        {liveForecast.claim}
      </p>
      <p class="mt-2 text-sm" style="color: var(--color-muted);">
        {liveForecast.horizon} · {liveForecast.resolution}
      </p>
    </div>
  </section>

  <!-- ── Charter doorway ────────────────────────────────────── -->
  <section class="mt-16">
    <a
      href="/governance/"
      class="surface-quiet flex flex-col gap-1 p-6 no-underline transition-colors hover:bg-[var(--color-surface-2)]"
    >
      <span class="eyebrow">Constitution</span>
      <strong class="serif text-xl" style="color: var(--color-ink);"
        >How this instrument keeps itself honest</strong
      >
      <span class="text-sm" style="color: var(--color-muted);"
        >Evidence discipline, revision in public, candidate vs. verified, and the
        defenses against its own drift.</span
      >
    </a>
  </section>
</Base>
