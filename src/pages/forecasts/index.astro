---
import Base from '../../layouts/Base.astro';
import { FORECASTS, type ForecastStatus } from '../../data/forecasts';
import { THEORY_BY_ID } from '../../data/theories';

const forecasts = [...FORECASTS].sort((a, b) => b.probability - a.probability);
const statusLabel: Record<ForecastStatus, string> = {
  open: 'Open',
  'resolved-yes': 'Resolved · yes',
  'resolved-no': 'Resolved · no',
};
---

<Base
  title="Forecast ledger — The Observatory"
  description="Predictions that punish vague confidence: every forecast carries a probability, a hard resolution criterion, and a horizon, so it can be scored when it resolves."
>
  <section class="max-w-3xl">
    <p class="eyebrow">Ledger · scoreable predictions</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">The forecast ledger</h1>
    <p class="lede mt-6">
      Vague confidence is not tracked here. Every forecast carries a
      probability, a hard resolution criterion, and a horizon — so it can be
      scored (Brier) when it resolves. A forecast you cannot lose is not a
      forecast.
    </p>
  </section>

  <ul class="mt-10 space-y-4">
    {
      forecasts.map((f) => (
        <li class="surface grid gap-5 p-6 sm:grid-cols-[7rem_1fr] sm:items-start">
          <div class="flex flex-col items-start gap-1">
            <p class="tabular text-4xl" style="color: var(--color-accent);">
              {Math.round(f.probability * 100)}%
            </p>
            <div
              class="h-1.5 w-full overflow-hidden rounded-full"
              style="background: var(--color-surface-2);"
            >
              <div
                class="h-full rounded-full"
                style={`width: ${Math.round(f.probability * 100)}%; background: var(--color-accent);`}
              />
            </div>
            <span class="mono mt-1 text-[0.65rem] uppercase tracking-wider" style="color: var(--color-muted);">
              {statusLabel[f.status]}
            </span>
          </div>

          <div>
            <p class="serif text-lg" style="color: var(--color-ink);">
              {f.claim}
            </p>
            <p class="mono mt-2 text-xs" style="color: var(--color-faint);">
              {f.horizon}
            </p>
            <p class="mt-3 text-sm" style="color: var(--color-muted);">
              <span class="eyebrow">Resolution</span>
              <span class="ml-2">{f.resolution}</span>
            </p>
            <div class="mt-3 flex flex-wrap gap-2">
              {f.theories.map((id) => {
                const t = THEORY_BY_ID[id];
                return (
                  <a
                    href={`/theories/${id}/`}
                    class="mono text-xs no-underline"
                    style={`color: ${t?.accent ?? 'var(--color-muted)'};`}
                  >
                    {t?.title ?? id}
                  </a>
                );
              })}
            </div>
          </div>
        </li>
      ))
    }
  </ul>

  <p class="mt-8 text-sm" style="color: var(--color-muted);">
    Probabilities are Observatory seed credences. When a forecast resolves, its
    Brier contribution goes on the record — including the ones the Observatory
    got wrong. That is the mechanism that keeps confidence honest.
  </p>
</Base>
