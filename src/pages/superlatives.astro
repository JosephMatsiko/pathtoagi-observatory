---
import Base from '../layouts/Base.astro';
import { SUPERLATIVES, type SuperlativeTrend } from '../data/superlatives';

const trendColor: Record<SuperlativeTrend, string> = {
  earning: 'var(--color-accent)',
  holding: 'var(--color-affirm)',
  slipping: 'var(--color-verdict)',
};
const trendGlyph: Record<SuperlativeTrend, string> = {
  earning: '▲ earning',
  holding: '■ holding',
  slipping: '▼ slipping',
};
---

<Base
  title="The Superlatives — pathtoAGI"
  description="Every commissioned superlative — smartest, wisest, most loving, most excellent — translated into a measurable obligation with an honest current reading. Obligations, never claims."
>
  <section class="max-w-3xl">
    <p class="eyebrow">The commission · obligations, never claims</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">The Superlatives</h1>
    <p class="lede mt-6">
      The commission was maximal: the most intelligent, the most wise, the most
      excellent, the most loving — every possible superlative. The proper form
      of the superlative is not boast. It is obligation.
    </p>
    <p class="prose mt-6">
      So every commissioned word lives here as a <strong>measurable
      obligation</strong> with an honest current reading. The instrument never
      announces itself as any of these things — it builds the machinery by which
      the words become increasingly <em>earned</em>, and it shows you the
      readings, including the unflattering ones. Skeptics are invited to grade
      it: the whole record is at
      <a href="/record.json" class="link-accent">/record.json</a>.
    </p>
  </section>

  <ul class="mt-10 space-y-3">
    {
      SUPERLATIVES.map((s) => (
        <li class="surface p-6">
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <h2 class="serif text-xl" style="color: var(--color-ink);">
              {s.word}
            </h2>
            <span class="mono text-xs" style={`color: ${trendColor[s.trend]};`}>
              {trendGlyph[s.trend]}
            </span>
          </div>
          <p class="mt-2 text-sm" style="color: var(--color-ink-dim);">
            {s.obligation}
          </p>
          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            <div>
              <p class="eyebrow">How it is measured</p>
              <p class="mt-1 text-sm" style="color: var(--color-muted);">
                {s.measure}
              </p>
            </div>
            <div>
              <p class="eyebrow">Honest reading · today</p>
              <p class="mt-1 text-sm" style="color: var(--color-muted);">
                {s.reading}
              </p>
            </div>
          </div>
        </li>
      ))
    }
  </ul>

  <p class="mt-8 max-w-3xl text-sm" style="color: var(--color-muted);">
    Readings move only on evidence — the maintenance mesh carries this register
    in its memory and works toward it every cycle, under the same gates as
    everything else. A reading that inflates without evidence is a drift event
    and gets retracted on the <a href="/log/" class="link-accent">public log</a>.
  </p>
</Base>
