---
import Base from '../../layouts/Base.astro';
import { THEORIES } from '../../data/theories';
import { computedPosteriors, PRIORS_PINNED_AT } from '../../data/inference';

const posteriors = Object.fromEntries(computedPosteriors().map((p) => [p.theoryId, p]));

const theories = [...THEORIES].sort((a, b) => b.health - a.health);
const trendGlyph: Record<string, string> = {
  gaining: '▲ gaining',
  holding: '■ holding',
  decelerating: '▼ decelerating',
};
---

<Base
  title="Five theories — pathtoAGI"
  description="The five live theories of how, or whether, AGI arrives — each with an Observatory health reading, the assumption it rests on, and the observation that would move it."
>
  <section class="max-w-3xl">
    <p class="eyebrow">Register · a contest, not a verdict</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">Five live theories</h1>
    <p class="lede mt-6">
      Each theory carries a 0–1 health reading — how much current evidence
      supports it — and a direction of travel. They are held in tension on
      purpose. The Observatory's job is to track which way the evidence moves,
      not to crown a winner.
    </p>
    <p class="mono mt-4 text-xs" style="color: var(--color-faint);">
      Two readings per theory: <span style="color: var(--color-ink-dim);">narrated</span> (discretionary, healthΔ-0 discipline) and
      <span style="color: var(--color-ink-dim);">computed</span> (pinned priors {PRIORS_PINNED_AT} × pre-registered likelihood ratios on new evidence, bounds [0.1, 10]).
      Divergence between them is itself information. Machinery in <a href="/record.json" class="hover:underline" style="color: var(--color-accent);">record.json</a>.
    </p>
  </section>

  <ul class="mt-10 space-y-3">
    {
      theories.map((t) => (
        <li>
          <a
            href={`/theories/${t.id}/`}
            class="surface block p-6 no-underline transition-colors hover:bg-[var(--color-surface-2)]"
          >
            <div class="flex flex-wrap items-center justify-between gap-2">
              <h2 class="serif text-xl" style="color: var(--color-ink);">
                {t.title}
              </h2>
              <span class="mono text-xs" style="color: var(--color-muted);">
                {trendGlyph[t.trend]}
              </span>
            </div>
            <p class="mt-1.5 text-sm" style="color: var(--color-muted);">
              {t.oneLine}
            </p>
            <div class="mt-4 flex items-center gap-3">
              <div
                class="h-2 flex-1 overflow-hidden rounded-full"
                style="background: var(--color-surface-2);"
              >
                <div
                  class="h-full rounded-full"
                  style={`width: ${Math.round(t.health * 100)}%; background: ${t.accent};`}
                />
              </div>
              <span class="tabular text-sm" style={`color: ${t.accent};`}>
                {t.health.toFixed(2)}
                <span class="ml-2 text-xs" style="color: var(--color-faint);" title={`Computed posterior: pinned priors × pre-registered likelihoods (${posteriors[t.id]?.evidenceApplied ?? 0} applied)`}>
                  · computed {posteriors[t.id]?.posterior.toFixed(2)}
                </span>
              </span>
            </div>
          </a>
        </li>
      ))
    }
  </ul>

  <p class="mt-8 text-sm" style="color: var(--color-muted);">
    Health readings are estimates, held open to revision. What makes them
    inspectable is on each theory's page: the assumption it rests on, and the
    single observation that would move it.
  </p>
</Base>
