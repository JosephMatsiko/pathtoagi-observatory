---
import Base from '../../layouts/Base.astro';
import {
  FORECASTS,
  calibration,
  brierOf,
  type ForecastStatus,
} from '../../data/forecasts';
import { THEORY_BY_ID } from '../../data/theories';

const open = FORECASTS.filter((f) => f.status === 'open').sort(
  (a, b) => b.probability - a.probability,
);
const resolved = FORECASTS.filter((f) => f.status !== 'open').sort((a, b) =>
  (b.resolvedAt ?? '').localeCompare(a.resolvedAt ?? ''),
);
const cal = calibration(FORECASTS);

const statusLabel: Record<ForecastStatus, string> = {
  open: 'Open',
  'resolved-yes': 'Resolved · yes',
  'resolved-no': 'Resolved · no',
};
const statusColor: Record<ForecastStatus, string> = {
  open: 'var(--color-accent)',
  'resolved-yes': 'var(--color-affirm)',
  'resolved-no': 'var(--color-verdict)',
};

const groups = [
  { heading: 'Open', items: open },
  { heading: 'Resolved', items: resolved },
];

const theoryTags = (f: { theories: string[] }) =>
  f.theories.map((id) => THEORY_BY_ID[id]).filter((t) => Boolean(t));
---

<Base
  title="Forecast ledger — pathtoAGI"
  description="Predictions that punish vague confidence: every forecast carries a probability, a hard resolution criterion, and a horizon, so it can be scored (Brier) when it resolves."
>
  <section class="max-w-3xl">
    <p class="eyebrow">Ledger · scoreable predictions</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">The forecast ledger</h1>
    <p class="lede mt-6">
      Vague confidence is not tracked here. Every forecast carries a
      probability, a hard resolution criterion, and a horizon — so it can be
      scored (Brier) when it resolves. A forecast you cannot lose is not a
      forecast.
    </p>
    <p class="mt-4 text-sm" style="color: var(--color-muted);">
      Every entry is <strong>pre-registered</strong>: its registration date is
      part of the record, the gate refuses registration at or past the horizon,
      and release commits are anchored into Bitcoin via OpenTimestamps — so the
      ordering of prediction and outcome can be verified by strangers, not
      taken on trust.
    </p>
  </section>

  <!-- Calibration panel -->
  <section class="mt-10 grid gap-4 sm:grid-cols-3">
    <div class="surface p-5">
      <p class="eyebrow">Mean Brier · live resolutions</p>
      <p class="tabular mt-2 text-4xl" style="color: var(--color-affirm);">
        {cal.meanBrier !== null ? cal.meanBrier.toFixed(3) : '—'}
      </p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">
        {
          cal.meanBrier === null
            ? 'Honestly empty: no forecast has resolved live yet. Calibration is unclaimed until one does.'
            : `Lower is better. 0 is perfect. Baselines to beat: coin-flip ${cal.baseline.toFixed(2)}${cal.baseRateBrier !== null ? `, base-rate ${cal.baseRateBrier.toFixed(3)}` : ''}.`
        }
      </p>
    </div>
    <div class="surface p-5">
      <p class="eyebrow">On the record</p>
      <p class="tabular mt-2 text-4xl" style="color: var(--color-ink);">
        {open.length}<span class="text-lg" style="color: var(--color-faint);">
          open</span
        >
      </p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">
        Live-resolved forecasts will keep their original probability — the
        misses stay counted.
      </p>
    </div>
    <div
      class="surface p-5"
      style="border-color: color-mix(in oklab, hsl(34 96% 60%) 35%, var(--color-line));"
    >
      <p class="eyebrow" style="color: hsl(34 96% 60%);">Retraction · self-audit</p>
      <p class="tabular mt-2 text-4xl" style="color: var(--color-ink);">
        {cal.backfilled}<span class="text-lg" style="color: var(--color-faint);">
          backfilled</span
        >
      </p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">
        Authored after their resolution dates — kept visible below, excluded
        from calibration. <a href="/log/" class="link-accent">Disclosure →</a>
      </p>
    </div>
  </section>

  {
    groups.map((group) => (
      <section class="mt-14">
        <h2 class="serif text-2xl">{group.heading}</h2>
        <ul class="mt-5 space-y-4">
          {group.items.map((f) => {
            const brier = brierOf(f);
            return (
              <li class="surface grid gap-5 p-6 sm:grid-cols-[8rem_1fr] sm:items-start">
                <div class="flex flex-col items-start">
                  <p class="tabular text-4xl" style={`color: ${statusColor[f.status]};`}>
                    {Math.round(f.probability * 100)}%
                  </p>
                  <div
                    class="mt-1.5 h-1.5 w-full overflow-hidden rounded-full"
                    style="background: var(--color-surface-2);"
                  >
                    <div
                      class="h-full rounded-full"
                      style={`width: ${Math.round(f.probability * 100)}%; background: ${statusColor[f.status]};`}
                    />
                  </div>
                  <span
                    class="mono mt-2 text-[0.65rem] uppercase tracking-wider"
                    style={`color: ${statusColor[f.status]};`}
                  >
                    {statusLabel[f.status]}
                  </span>
                  {f.provenance === 'backfilled' && (
                    <span
                      class="mono mt-1 rounded px-1.5 py-0.5 text-[0.6rem] uppercase tracking-wider"
                      style="background: var(--color-surface-2); color: hsl(34 96% 60%);"
                    >
                      backfilled · not scored
                    </span>
                  )}
                  {brier !== null && f.provenance !== 'backfilled' && (
                    <span class="mono mt-1 text-[0.7rem]" style="color: var(--color-ink-dim);">
                      brier {brier.toFixed(3)}
                    </span>
                  )}
                </div>

                <div>
                  <p class="serif text-lg" style="color: var(--color-ink);">
                    {f.claim}
                  </p>
                  <p class="mono mt-2 text-xs" style="color: var(--color-faint);">
                    {f.horizon}
                    {f.resolvedAt && ` · resolved ${f.resolvedAt}`}
                  </p>
                  <p class="mt-3 text-sm" style="color: var(--color-muted);">
                    <span class="eyebrow">Resolution</span>
                    <span class="ml-2">{f.resolution}</span>
                  </p>
                  {f.resolvedNote && (
                    <p class="mt-2 text-sm" style="color: var(--color-ink-dim);">
                      {f.resolvedNote}
                    </p>
                  )}
                  <div class="mt-3 flex flex-wrap gap-2">
                    {theoryTags(f).map((t) => (
                      <a
                        href={`/theories/${t.id}/`}
                        class="mono text-xs no-underline"
                        style={`color: ${t.accent};`}
                      >
                        {t.title}
                      </a>
                    ))}
                  </div>
                </div>
              </li>
            );
          })}
        </ul>
      </section>
    ))
  }
</Base>

<script></script>
