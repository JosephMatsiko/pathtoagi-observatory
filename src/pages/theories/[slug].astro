---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { THEORY_BY_ID } from '../../data/theories';
import { EVIDENCE, EVIDENCE_CLASS_LABEL } from '../../data/evidence';

export async function getStaticPaths() {
  const entries = await getCollection('theories');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const meta = THEORY_BY_ID[entry.data.id];
const linkedEvidence = EVIDENCE.filter((e) => e.theories.includes(entry.data.id));
const accent = entry.data.accent;
---

<Base title={`${entry.data.title} — The Observatory`} description={meta?.oneLine}>
  <a href="/theories/" class="mono text-sm no-underline" style="color: var(--color-muted);"
    >← five theories</a
  >

  <div class="mt-5 flex flex-wrap items-center gap-3">
    <span
      class="inline-block h-3 w-3 rounded-full"
      style={`background: ${accent}; box-shadow: 0 0 14px ${accent};`}
    ></span>
    <h1 class="display text-4xl" style="color: var(--color-ink);">
      {entry.data.title}
    </h1>
  </div>

  <div class="mt-4 flex items-center gap-3">
    <div
      class="h-2 w-48 overflow-hidden rounded-full"
      style="background: var(--color-surface-2);"
    >
      <div
        class="h-full rounded-full"
        style={`width: ${Math.round(entry.data.health * 100)}%; background: ${accent};`}
      >
      </div>
    </div>
    <span class="tabular text-sm" style={`color: ${accent};`}>
      health {entry.data.health.toFixed(2)}
    </span>
    {
      meta && (
        <span class="mono text-xs" style="color: var(--color-muted);">
          · {meta.trend}
        </span>
      )
    }
  </div>

  <div class="mt-10 grid gap-10 lg:grid-cols-[minmax(0,1fr)_17rem]">
    <article class="prose max-w-2xl">
      <Content />
    </article>

    <aside class="space-y-4">
      {
        meta && (
          <>
            <div class="surface-quiet p-5">
              <p class="eyebrow">Who holds it</p>
              <ul class="mt-2 space-y-1">
                {meta.proponents.map((p) => (
                  <li class="text-sm serif" style="color: var(--color-ink-dim);">
                    {p}
                  </li>
                ))}
              </ul>
            </div>
            <div class="surface-quiet p-5">
              <p class="eyebrow">Load-bearing assumption</p>
              <p class="mt-2 text-sm serif" style="color: var(--color-ink-dim);">
                {meta.loadBearing}
              </p>
            </div>
            <div
              class="surface p-5"
              style={`border-color: color-mix(in oklab, ${accent} 40%, var(--color-line));`}
            >
              <p class="eyebrow" style={`color: ${accent};`}>
                What would move it
              </p>
              <p class="mt-2 text-sm serif" style="color: var(--color-ink);">
                {meta.falsifier}
              </p>
            </div>
          </>
        )
      }
    </aside>
  </div>

  {
    linkedEvidence.length > 0 && (
      <section class="mt-12">
        <p class="eyebrow">Linked evidence · {linkedEvidence.length}</p>
        <ul class="mt-3 space-y-2">
          {linkedEvidence.map((e) => (
            <li class="surface-quiet flex flex-wrap items-baseline gap-x-3 gap-y-1 p-4">
              <span class="mono text-xs" style="color: var(--color-faint);">
                {e.observedAt} · {EVIDENCE_CLASS_LABEL[e.class]}
              </span>
              <a href="/evidence/" class="text-sm no-underline" style="color: var(--color-ink-dim);">
                {e.signal}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <p class="mono mt-10 text-xs" style="color: var(--color-faint);">
    Last updated {entry.data.updated}
  </p>
</Base>
