---
import Base from '../../layouts/Base.astro';
import { RUN_BUNDLES, RUN_BUNDLE_STATUS_LABEL } from '../../data/run-bundles';

const latest = [...RUN_BUNDLES].sort((a, b) => b.registeredAt.localeCompare(a.registeredAt))[0];
---

<Base
  title="Runs - pathtoAGI"
  description="Omnibus run bundles for the Observatory: registered protocols, sealed worlds, controls, pending gates, and reproduction artifacts."
>
  <section class="max-w-3xl">
    <p class="eyebrow">Runs · Omnibus bundles</p>
    <h1 class="display mt-4 text-4xl sm:text-5xl">Protocol before result</h1>
    <p class="lede mt-6">
      This surface is for governed run bundles: manifests, prompts, seals,
      scoring rubrics, baseline requirements, receipts, and pending gates.
      Registered does not mean solved. Sealed does not mean evidence. The record
      moves only when the protocol survives its own controls.
    </p>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-3">
    <div class="surface-quiet p-5">
      <p class="eyebrow">Run bundles</p>
      <p class="tabular mt-2 text-3xl" style="color: var(--color-ink);">{RUN_BUNDLES.length}</p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">Omnibus-form registered objects</p>
    </div>
    <div class="surface-quiet p-5">
      <p class="eyebrow">Latest</p>
      <p class="mono mt-2 text-sm" style="color: var(--color-ink);">{latest?.id ?? 'none'}</p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">{latest?.registeredAt ?? 'no registered bundle'}</p>
    </div>
    <div class="surface-quiet p-5">
      <p class="eyebrow">Verdict impact</p>
      <p class="tabular mt-2 text-3xl" style="color: var(--color-verdict);">0</p>
      <p class="mt-1 text-sm" style="color: var(--color-muted);">no bundle has completed gates</p>
    </div>
  </section>

  <section class="mt-14 space-y-5">
    {
      RUN_BUNDLES.map((bundle) => (
        <article class="surface p-6">
          <div class="flex flex-wrap items-center gap-3">
            <span class="mono text-xs" style="color: var(--color-accent);">{bundle.id}</span>
            <span class="mono text-xs" style="color: var(--color-faint);">{bundle.registeredAt}</span>
            <span class="mono rounded px-1.5 py-0.5 text-[0.62rem] uppercase tracking-wider" style="background: var(--color-surface-2); color: var(--color-ink-dim);">
              {RUN_BUNDLE_STATUS_LABEL[bundle.status]}
            </span>
          </div>
          <h2 class="serif mt-3 text-2xl" style="color: var(--color-ink);">{bundle.title}</h2>
          <p class="mt-2 max-w-3xl text-sm" style="color: var(--color-muted);">{bundle.summary}</p>

          <div class="mt-5 grid gap-5 lg:grid-cols-[1fr_0.9fr]">
            <div>
              <p class="eyebrow">Controls</p>
              <ul class="mt-3 grid gap-2 sm:grid-cols-2">
                {bundle.controls.map((control) => (
                  <li class="border-l-2 pl-3 text-sm" style="border-color: var(--color-line); color: var(--color-ink-dim);">
                    {control}
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <p class="eyebrow">Pending before evidence</p>
              <p class="mt-3 flex flex-wrap gap-2">
                {bundle.pending.map((item) => (
                  <span class="mono rounded px-2 py-1 text-[0.68rem]" style="background: var(--color-surface-2); color: var(--color-muted);">{item}</span>
                ))}
              </p>
            </div>
          </div>

          <div class="mt-5 flex flex-wrap gap-4 text-sm">
            <a href={bundle.manifestPath} class="link-accent">manifest</a>
            <a href="/runs/fcs-world-003-2026-07-02/01_protocol.md" class="link-accent">protocol</a>
            <a href="/runs/fcs-world-003-2026-07-02/05_attempt_template.json" class="link-accent">attempt template</a>
            <a href="/evaluation-kit/fcs-world-003/README.md" class="link-accent">evaluation kit</a>
          </div>
        </article>
      ))
    }
  </section>
</Base>
