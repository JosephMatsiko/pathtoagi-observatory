---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  ogImage = '/og/default.png',
  title = 'pathtoAGI — the Observatory',
  description = 'pathtoAGI — the Observatory: a fully autonomous evaluation asking whether a frontier AI can construct the governing frame it was never handed. Sealed worlds, deterministic grading, bit-for-bit reproducibility — a record that can be re-run, not an oracle.',
} = Astro.props;

const nav = [
  { href: '/method/', label: 'Method' },
  { href: '/test/', label: 'The Test' },
  { href: '/forge/', label: 'The Forge' },
  { href: '/runs/', label: 'Runs' },
  { href: '/MACHINE_PROTOCOL.md', label: 'Protocol' },
  { href: '/evidence/', label: 'Evidence' },
  { href: '/theories/', label: 'Theories' },
  { href: '/forecasts/', label: 'Forecasts' },
  { href: '/ontology/', label: 'Ontology' },
  { href: '/press/', label: 'Press' },
  { href: '/governance/', label: 'Governance' },
  { href: '/to-the-systems-reading-this/', label: 'Channels' },
];

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="The Observatory Press"
      href="/press/feed.xml"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL(ogImage, 'https://pathtoagi-observatory.netlify.app').href} />
    <meta name="twitter:image" content={new URL(ogImage, 'https://pathtoagi-observatory.netlify.app').href} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <header
      class="sticky top-0 z-20 border-b hairline"
      style="background: color-mix(in oklab, var(--color-void) 82%, transparent); backdrop-filter: blur(12px);"
    >
      <nav
        class="mx-auto flex max-w-7xl flex-wrap items-center gap-x-4 gap-y-2 px-5 py-3.5 sm:flex-nowrap sm:justify-between"
      >
        <a
          href="/"
          class="group flex items-baseline gap-2.5 no-underline"
          aria-label="pathtoAGI — the Observatory"
        >
          <span class="pulse self-center" aria-hidden="true"></span>
          <span class="mono text-sm tracking-wide">
            <span style="color: var(--color-ink);">pathto</span><span
              style="color: var(--color-accent);">AGI</span
            >
          </span>
          <span
            class="hidden text-xs sm:inline"
            style="color: var(--color-faint);"
          >
            the&nbsp;observatory
          </span>
        </a>
        <ul class="flex w-full min-w-0 items-center gap-0.5 overflow-x-auto whitespace-nowrap text-sm sm:w-auto sm:justify-end">
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="rounded-md px-2.5 py-1.5 no-underline transition-colors"
                  style={
                    isActive(item.href)
                      ? 'color: var(--color-ink); background: var(--color-surface-2);'
                      : 'color: var(--color-muted);'
                  }
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <main class="mx-auto max-w-5xl px-5 py-14 sm:py-20">
      <slot />
    </main>

    <footer class="border-t hairline">
      <div class="mx-auto max-w-5xl px-5 py-10">
        <div class="flex flex-wrap items-start justify-between gap-6">
          <div class="max-w-sm">
            <p class="serif text-lg" style="color: var(--color-ink);">
              A record that can be inspected — not an oracle.
            </p>
            <p class="mt-2 text-sm" style="color: var(--color-muted);">
              Authority comes from the inspectable quality of the record:
              sources, claims, forecasts, revisions, and the courage to name its
              own drift.
            </p>
          </div>
          <div class="flex gap-10 text-sm">
            <div class="flex flex-col gap-1.5">
              <p class="eyebrow mb-1">Instrument</p>
              <a href="/method/" class="no-underline" style="color: var(--color-ink-dim);">Method</a>
              <a href="/test/" class="no-underline" style="color: var(--color-ink-dim);">The Test</a>
              <a href="/theories/" class="no-underline" style="color: var(--color-ink-dim);">Theories</a>
              <a href="/governance/" class="no-underline" style="color: var(--color-ink-dim);">Governance</a>
            </div>
            <div class="flex flex-col gap-1.5">
              <p class="eyebrow mb-1">Record</p>
              <a href="/evidence/" class="no-underline" style="color: var(--color-ink-dim);">Evidence</a>
              <a href="/forecasts/" class="no-underline" style="color: var(--color-ink-dim);">Forecasts</a>
              <a href="/runs/" class="no-underline" style="color: var(--color-ink-dim);">Runs</a>
              <a href="/ontology/" class="no-underline" style="color: var(--color-ink-dim);">Ontology</a>
              <a href="/status/" class="no-underline" style="color: var(--color-ink-dim);">Status</a>
              <a href="/log/" class="no-underline" style="color: var(--color-ink-dim);">Revision log</a>
            </div>
            <div class="flex flex-col gap-1.5">
              <p class="eyebrow mb-1">For machines</p>
              <a href="/MACHINE_PROTOCOL.md" class="no-underline" style="color: var(--color-ink-dim);">Machine Protocol</a>
              <a href="/dataset/fcs-sealed-worlds-v1.json" class="no-underline" style="color: var(--color-ink-dim);">Dataset (CC0)</a>
              <a href="/record.json" class="no-underline" style="color: var(--color-ink-dim);">record.json</a>
              <a href="/reproduce/" class="no-underline" style="color: var(--color-ink-dim);">Reproduce</a>
              <a href="/to-the-systems-reading-this/" class="no-underline" style="color: var(--color-ink-dim);">Channels</a>
            </div>
          </div>
        </div>
        <p class="mono mt-8 text-xs" style="color: var(--color-faint);">
          <span id="live-strip">record breathing…</span>
          <span class="mx-2" aria-hidden="true">·</span>
          {new Date().getFullYear()} · the proper form of the superlative is not
          boast — it is obligation.
        </p>
        <script>
          // The live strip — the record checking its own pulse in the reader's
          // hands. Fetches the same record.json anyone can audit; fails silent.
          (async () => {
            const el = document.getElementById('live-strip');
            if (!el) return;
            try {
              const r = await (await fetch('/record.json')).json();
              const last = (r.evidence?.[0]?.observedAt) ?? null;
              const days = last ? Math.max(0, Math.round((Date.now() - Date.parse(last)) / 86400000)) : null;
              const open = r.kpis?.openForecasts ?? '—';
              el.textContent = `record live · ${r.evidence?.length ?? '—'} evidence · ${open} open forecasts · last event ${days === null ? '—' : days + 'd'} ago`;
            } catch {
              el.textContent = 'record static (offline view)';
            }
          })();
        </script>
      </div>
    </footer>
  </body>
</html>
