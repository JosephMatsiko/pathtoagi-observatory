---
// The record atlas, drawn from the computed ontology — no hand-placed data.
// Types are grouped into layer columns; every count on screen is derived from
// the record at build time and gate-checked for referential integrity.
import { ONTOLOGY, ONTOLOGY_EDGES, ONTOLOGY_NODES, PERMITTED_ACTIONS } from '../data/ontology';

const LAYERS: { id: string; label: string }[] = [
  { id: 'record', label: 'Record' },
  { id: 'evaluation', label: 'Evaluation' },
  { id: 'review', label: 'Review' },
  { id: 'interface', label: 'Interface' },
];

// Column layout: x by layer, y by position within the layer.
const colW = 236, boxW = 190, boxH = 46, vGap = 14, topPad = 46, leftPad = 24;
const positions = new Map<string, { x: number; y: number }>();
let maxRows = 0;
for (const [li, layer] of LAYERS.entries()) {
  const members = ONTOLOGY_NODES.filter((n) => n.layer === layer.id);
  maxRows = Math.max(maxRows, members.length);
  members.forEach((n, i) => {
    positions.set(n.id, {
      x: leftPad + li * colW + boxW / 2,
      y: topPad + i * (boxH + vGap) + boxH / 2,
    });
  });
}
const width = leftPad * 2 + LAYERS.length * colW - (colW - boxW);
const height = topPad + maxRows * (boxH + vGap) + 12;
const nodeById = new Map(ONTOLOGY_NODES.map((n) => [n.id, n]));
---

<section class="ops-frame overflow-hidden">
  <div class="grid gap-0 lg:grid-cols-[1fr_18rem]">
    <div class="p-5 sm:p-6">
      <div class="flex flex-wrap items-baseline justify-between gap-3">
        <div>
          <p class="eyebrow">Record atlas · objects and trails</p>
          <h2 class="serif mt-1 text-2xl" style="color: var(--color-ink);">What can be cited, tested, and repaired</h2>
        </div>
        <a href="/record.json" class="mono text-xs link-accent">record.json</a>
      </div>
      <div class="mt-5 overflow-x-auto">
        <svg viewBox={`0 0 ${width} ${height}`} class="w-full" style={`min-width: ${width * 0.72}px;`} role="img" aria-label="Ontology atlas: every governed object type on the record, grouped by layer, with computed counts and typed relationships.">
          <defs>
            <marker id="ontology-arrow" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="6" markerHeight="6" orient="auto">
              <path d="M0,0 L8,4 L0,8 z" fill="var(--color-line)"></path>
            </marker>
          </defs>
          <rect width={width} height={height} rx="14" fill="color-mix(in oklab, var(--color-surface) 62%, transparent)" stroke="var(--color-line)"></rect>
          {LAYERS.map((layer, li) => (
            <text x={leftPad + li * colW + boxW / 2} y={26} text-anchor="middle" class="ontology-layer">{layer.label}</text>
          ))}
          {ONTOLOGY_EDGES.map((edge) => {
            const a = positions.get(edge.from);
            const b = positions.get(edge.to);
            if (!a || !b) return null;
            const x1 = a.x + (b.x > a.x ? boxW / 2 : b.x < a.x ? -boxW / 2 : 0);
            const x2 = b.x + (a.x > b.x ? boxW / 2 : a.x < b.x ? -boxW / 2 : 0);
            const y1 = a.y + (a.x === b.x ? (b.y > a.y ? boxH / 2 : -boxH / 2) : 0);
            const y2 = b.y + (a.x === b.x ? (a.y > b.y ? boxH / 2 : -boxH / 2) : 0);
            return (
              <line x1={x1} y1={y1} x2={x2} y2={y2} stroke="var(--color-line)" stroke-width="1" stroke-dasharray="4 7" opacity="0.7" marker-end="url(#ontology-arrow)">
                <title>{`${nodeById.get(edge.from)?.label} ${edge.relation} ${nodeById.get(edge.to)?.label}`}</title>
              </line>
            );
          })}
          {ONTOLOGY_NODES.map((node) => {
            const p = positions.get(node.id)!;
            return (
              <a href={node.href}>
                <g class="ontology-node">
                  <rect x={p.x - boxW / 2} y={p.y - boxH / 2} width={boxW} height={boxH} rx="6" fill="var(--color-surface)" stroke={node.accent} stroke-opacity="0.72"></rect>
                  <circle cx={p.x - boxW / 2 + 16} cy={p.y} r="3.5" fill={node.accent}></circle>
                  <text x={p.x - boxW / 2 + 28} y={p.y - 3} class="ontology-label">{node.label}</text>
                  <text x={p.x - boxW / 2 + 28} y={p.y + 12} class="ontology-state">{node.state}</text>
                </g>
              </a>
            );
          })}
        </svg>
      </div>
      <p class="mono mt-3 text-[0.66rem]" style="color: var(--color-faint);">
        {ONTOLOGY.integrity.nodes} governed objects · {ONTOLOGY.integrity.edges} typed edges ·
        {ONTOLOGY.integrity.verifiedArtifactRefs} artifact references verified on disk ·
        {ONTOLOGY.integrity.danglingTypedRefs.length} dangling — every figure computed from the record at build time and enforced by the conformance gate.
      </p>
    </div>
    <aside class="border-t p-5 lg:border-l lg:border-t-0 hairline">
      <p class="eyebrow">Allowed record moves</p>
      <p class="mt-2 text-sm" style="color: var(--color-muted);">
        The atlas is useful only where it constrains action. Each object type
        carries its own permitted subset — a forecast can be frozen and graded
        but never retired into silence; an incident can be corrected but never
        deleted.
      </p>
      <p class="mt-4 flex flex-wrap gap-2">
        {PERMITTED_ACTIONS.map((action) => (
          <span class="mono rounded px-2 py-1 text-[0.66rem]" style="background: var(--color-surface-2); color: var(--color-ink-dim);">{action}</span>
        ))}
      </p>
    </aside>
  </div>
</section>

<style>
  .ontology-label {
    fill: var(--color-ink);
    font-family: var(--font-serif);
    font-size: 12px;
  }
  .ontology-state {
    fill: var(--color-faint);
    font-family: var(--font-mono);
    font-size: 7.5px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .ontology-layer {
    fill: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .ontology-node {
    transition: opacity 160ms var(--ease-out);
  }
  .ontology-node:hover {
    opacity: 0.78;
  }
</style>
